  }

  #accessible-preview[data-font-size='lg'] .product-btn-preview {
    padding-top: 1.05rem;
    padding-bottom: 1.05rem;
  }

  #accessible-preview[data-accessible='off'] #accessible-preview-panel {
    border-color: rgba(148, 163, 184, 0.22);
    background: #0b1220;
    box-shadow: none;
  }

  #accessible-preview[data-accessible='off'] .product-btn-preview {
    background: #263244;
    border-color: rgba(148, 163, 184, 0.2);
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  #accessible-preview[data-accessible='off'] #preview-help-text {
