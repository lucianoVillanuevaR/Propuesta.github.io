  }

  #accessible-preview[data-accessible='off'] #preview-guide-box {
    border-color: rgba(148, 163, 184, 0.25);
    background: rgba(148, 163, 184, 0.06);
  }

  #accessible-preview[data-accessible='off'] #preview-progress-bar {
    background: #64748b;
    width: 35% !important;
