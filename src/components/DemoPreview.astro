</style>

<script>
  (() => {
    const demo = document.getElementById('accessible-preview');
    if (!demo) return;

    const toggleAccessible = document.getElementById('toggle-accessible-preview');
    const accessibleBadge = document.getElementById('accessible-preview-badge');
    const stepLabel = document.getElementById('preview-step-label');
    const helpText = document.getElementById('preview-help-text');
    const guideText = document.getElementById('preview-guide-text');
    const progressBar = document.getElementById('preview-progress-bar');
    const helpToggle = document.getElementById('preview-help-toggle');
    const helpPanel = document.getElementById('preview-help-panel');
    const addAnotherBtn = document.getElementById('preview-add-another-btn');
    const summaryList = document.getElementById('preview-summary-list');
    const confirmBtn = document.getElementById('preview-confirm-btn');
    const nextBtn = document.getElementById('preview-next-btn');
    const backBtn = document.getElementById('preview-back-btn');
    const successBox = document.getElementById('preview-success-box');
    const errorBox = document.getElementById('preview-error-box');
    const statusPill = document.getElementById('preview-status-pill');
    const productButtons = Array.from(demo.querySelectorAll('.product-btn-preview'));
    const fontButtons = Array.from(demo.querySelectorAll('.font-btn-preview'));

    let selectedProducts = [];
    let accessibleMode = true;
    let currentStep = 1;
    let awaitingFinalConfirm = false;

    function renderSummary() {
      if (!summaryList) return;

      if (selectedProducts.length === 0) {
        summaryList.innerHTML = '<p class="text-slate-500">Aun no hay productos seleccionados.</p>';
        return;
      }

      summaryList.innerHTML = selectedProducts
        .map(
          (product) => `
            <div class="flex justify-between gap-4">
              <span>${product}</span>
              <span>1</span>
            </div>
          `
        )
        .join('');
    }

    function updateStepUI() {
      const hasProducts = selectedProducts.length > 0;

      if (stepLabel) {
        stepLabel.textContent = currentStep === 1 ? 'Paso 1 de 2 - Selecciona productos' : 'Paso 2 de 2 - Revisa y confirma';
      }

      if (guideText) {
        guideText.textContent =
          currentStep === 1
            ? 'Paso 1: toca uno o más productos y luego presiona "Siguiente".'
            : 'Paso 2: revisa el resumen y confirma el pedido.';
      }

      if (progressBar) {
        progressBar.style.width = currentStep === 1 ? '50%' : '100%';
      }

      if (helpText) {
        helpText.textContent =
          currentStep === 1
            ? 'Selecciona los productos con botones grandes y visibles.'
            : 'Revisa el resumen. Si está correcto, confirma en el botón verde.';
      }

      if (backBtn) {
        backBtn.disabled = currentStep === 1;
      }

      if (nextBtn) {
        nextBtn.disabled = currentStep === 2 || !hasProducts;
      }

      if (confirmBtn) {
        confirmBtn.disabled = currentStep !== 2 || !hasProducts;
        confirmBtn.classList.toggle('hidden', currentStep !== 2);
      }

      if (statusPill) {
        if (!hasProducts) statusPill.textContent = 'Sin errores';
        if (hasProducts && currentStep === 1) statusPill.textContent = 'Listo para revisar';
        if (hasProducts && currentStep === 2) statusPill.textContent = 'Listo para confirmar';
      }
    }

    function updateProductStyles() {
      productButtons.forEach((button) => {
        const product = button.getAttribute('data-product');
        const action = button.querySelector('.preview-action');
        const isSelected = product ? selectedProducts.includes(product) : false;

        button.classList.toggle('border-green-500/50', isSelected);
        button.classList.toggle('bg-green-500/20', isSelected);
        button.classList.toggle('hover:bg-green-500/25', isSelected);
        button.classList.toggle('ring-2', isSelected);
        button.classList.toggle('ring-green-400/20', isSelected);
        button.classList.toggle('bg-[#334155]', !isSelected);
        button.classList.toggle('hover:bg-[#3b4a61]', !isSelected);
        button.setAttribute('aria-pressed', String(isSelected));

        if (action) {
          action.textContent = isSelected ? 'Agregado' : 'Agregar al pedido';
        }
      });
    }

    function setAccessibleMode(on) {
      accessibleMode = on;
      demo.dataset.accessible = on ? 'on' : 'off';

      if (toggleAccessible) {
        toggleAccessible.textContent = on ? 'Modo accesible: ON' : 'Modo accesible: OFF';
        toggleAccessible.setAttribute('aria-pressed', String(on));
        toggleAccessible.className = on
          ? 'rounded-full border border-green-400/20 bg-green-500/10 px-4 py-2 text-sm font-medium text-green-300 transition hover:bg-green-500/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-300 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a1324]'
          : 'rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-white transition hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-300 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a1324]';
      }

      if (accessibleBadge) {
        accessibleBadge.textContent = on ? 'Interfaz accesible' : 'Vista estándar';
        accessibleBadge.className = on
          ? 'rounded-full bg-green-500/15 px-3 py-1 text-xs font-medium text-green-400'
          : 'rounded-full bg-slate-500/20 px-3 py-1 text-xs font-medium text-slate-300';
      }

      if (helpText) {
        helpText.textContent = on
          ? 'Modo accesible activo: mayor contraste, botones grandes y lectura más clara.'
          : 'Vista estándar: mantiene el flujo simple, pero con menos apoyo visual.';
      }

      if (guideText && currentStep === 1) {
        guideText.textContent = on
          ? 'Paso 1: toca uno o más productos y luego presiona "Siguiente".'
          : 'Paso 1: selecciona productos para continuar.';
      }

      if (helpToggle) {
        helpToggle.disabled = !on;
        helpToggle.classList.toggle('opacity-50', !on);
        helpToggle.classList.toggle('cursor-not-allowed', !on);
      }

      if (!on && helpPanel) {
        helpPanel.classList.add('hidden');
        if (helpToggle) helpToggle.setAttribute('aria-expanded', 'false');
      }

      fontButtons.forEach((button) => {
        button.disabled = !on;
        button.classList.toggle('opacity-50', !on);
        button.classList.toggle('cursor-not-allowed', !on);
      });
    }

    function setFontSize(size) {
      demo.dataset.fontSize = size;

      fontButtons.forEach((button) => {
        const isActive = button.getAttribute('data-font') === size;
        button.setAttribute('aria-pressed', String(isActive));
        button.classList.toggle('bg-[#1f2937]', isActive);
        button.classList.toggle('bg-[#111827]', !isActive);
      });
    }

    productButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const product = button.getAttribute('data-product');
        if (!product) return;

        if (selectedProducts.includes(product)) {
          selectedProducts = selectedProducts.filter((item) => item !== product);
        } else {
          selectedProducts.push(product);
        }

        if (errorBox) errorBox.classList.add('hidden');
        if (successBox) successBox.classList.add('hidden');
        awaitingFinalConfirm = false;
        if (confirmBtn) confirmBtn.textContent = 'Confirmar pedido';

        renderSummary();
        updateProductStyles();
        updateStepUI();
      });
    });

    fontButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const size = button.getAttribute('data-font') || 'base';
        setFontSize(size);
      });
    });

    if (toggleAccessible) {
      toggleAccessible.addEventListener('click', () => {
        setAccessibleMode(!accessibleMode);
        updateStepUI();
      });
    }

    if (helpToggle && helpPanel) {
      helpToggle.addEventListener('click', () => {
        const opened = !helpPanel.classList.contains('hidden');
        helpPanel.classList.toggle('hidden', opened);
        helpToggle.setAttribute('aria-expanded', String(!opened));
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        if (selectedProducts.length === 0) return;
        currentStep = 2;
        awaitingFinalConfirm = false;
        if (confirmBtn) confirmBtn.textContent = 'Confirmar pedido';
        if (errorBox) errorBox.classList.add('hidden');
        if (successBox) successBox.classList.add('hidden');
        updateStepUI();
      });
    }

    if (backBtn) {
      backBtn.addEventListener('click', () => {
        currentStep = 1;
        awaitingFinalConfirm = false;
        if (confirmBtn) confirmBtn.textContent = 'Confirmar pedido';
        if (errorBox) errorBox.classList.add('hidden');
        if (successBox) successBox.classList.add('hidden');
        updateStepUI();
      });
    }

    if (addAnotherBtn) {
      addAnotherBtn.addEventListener('click', () => {
        currentStep = 1;
        awaitingFinalConfirm = false;
        if (confirmBtn) confirmBtn.textContent = 'Confirmar pedido';
        if (errorBox) errorBox.classList.add('hidden');
        if (successBox) successBox.classList.add('hidden');
        updateStepUI();
        const firstProduct = productButtons[0];
        if (firstProduct instanceof HTMLElement) firstProduct.focus();
      });
    }

    if (confirmBtn) {
      confirmBtn.addEventListener('click', () => {
        if (currentStep !== 2 || selectedProducts.length === 0) {
          if (errorBox) errorBox.classList.remove('hidden');
          if (successBox) successBox.classList.add('hidden');
          if (statusPill) statusPill.textContent = 'Falta seleccionar';
          return;
        }

        if (!awaitingFinalConfirm) {
          awaitingFinalConfirm = true;
          if (confirmBtn) confirmBtn.textContent = 'Presiona de nuevo para confirmar';
          if (errorBox) errorBox.classList.add('hidden');
          if (successBox) successBox.classList.add('hidden');
          if (statusPill) statusPill.textContent = 'Confirmacion asistida';
          return;
        }

        awaitingFinalConfirm = false;
        if (confirmBtn) confirmBtn.textContent = 'Confirmar pedido';
        if (errorBox) errorBox.classList.add('hidden');
        if (successBox) successBox.classList.remove('hidden');
        if (statusPill) statusPill.textContent = 'Sin errores';
      });
    }

    renderSummary();
    updateProductStyles();
    setFontSize('base');
    setAccessibleMode(true);
    updateStepUI();
  })();
</script>
