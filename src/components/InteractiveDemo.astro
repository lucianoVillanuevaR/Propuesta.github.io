<script define:vars={{ prototypeSteps }}>
  (() => {
    const TAB_ACTIVE =
      'prototype-tab rounded-full border border-sky-400/40 bg-sky-400/15 px-5 py-3 text-sm font-semibold text-sky-200 transition';
    const TAB_INACTIVE =
      'prototype-tab rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-slate-300 transition hover:bg-white/10';
    const MODE_ON_ACTIVE =
      'mode-toggle rounded-full border border-green-400/20 bg-green-500/15 px-4 py-2 text-sm font-semibold text-green-200 transition';
    const MODE_OFF_ACTIVE =
      'mode-toggle rounded-full border border-slate-400/20 bg-slate-400/15 px-4 py-2 text-sm font-semibold text-slate-100 transition';
    const MODE_INACTIVE =
      'mode-toggle rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-slate-300 transition hover:bg-white/10';
    const FONT_ACTIVE =
      'font-toggle rounded-full border border-sky-400/30 bg-sky-400/15 px-3 py-2 text-sm font-semibold text-sky-100 transition';
    const FONT_INACTIVE =
      'font-toggle rounded-full border border-white/10 bg-white/5 px-3 py-2 text-sm font-semibold text-slate-200 transition hover:bg-white/10';

    const demoRoot = document.getElementById('demo-prototypes');
    const tabs = Array.from(document.querySelectorAll('.prototype-tab'));
    const panels = Array.from(document.querySelectorAll('.prototype-panel'));
    const sideTitle = document.getElementById('prototype-side-title');
    const sideDescription = document.getElementById('prototype-side-description');
    const sideList = document.getElementById('prototype-side-list');
    const modeButtons = Array.from(document.querySelectorAll('.mode-toggle'));
    const fontButtons = Array.from(document.querySelectorAll('.font-toggle'));
    const modeCopy = document.getElementById('accessibility-mode-copy');
    const captureModeBadge = document.getElementById('capture-mode-badge');
    const summaryCopy = document.getElementById('summary-copy');
    const summaryBadge = document.getElementById('summary-badge');
    const feature1Title = document.getElementById('feature-1-title');
    const feature1Copy = document.getElementById('feature-1-copy');
    const feature2Title = document.getElementById('feature-2-title');
    const feature2Copy = document.getElementById('feature-2-copy');
    const feature3Title = document.getElementById('feature-3-title');
    const feature3Copy = document.getElementById('feature-3-copy');
    const modeInfo1Title = document.getElementById('mode-info-1-title');
    const modeInfo1Copy = document.getElementById('mode-info-1-copy');
    const modeInfo2Title = document.getElementById('mode-info-2-title');
    const modeInfo2Copy = document.getElementById('mode-info-2-copy');
    const modeInfo3Title = document.getElementById('mode-info-3-title');
    const modeInfo3Copy = document.getElementById('mode-info-3-copy');

    function setFontSize(size) {
      if (!demoRoot) return;
      demoRoot.dataset.fontSize = size;

      fontButtons.forEach((button) => {
        const active = button.getAttribute('data-font-size') === size;
        button.setAttribute('aria-pressed', String(active));
        button.className = active ? FONT_ACTIVE : FONT_INACTIVE;
      });
    }

    function setAccessibilityMode(mode) {
      if (!demoRoot) return;

      const accessible = mode === 'on';
      demoRoot.dataset.accessibilityMode = mode;

      modeButtons.forEach((button) => {
        const active = button.getAttribute('data-mode') === mode;
        button.setAttribute('aria-pressed', String(active));
        button.className = active ? (accessible ? MODE_ON_ACTIVE : MODE_OFF_ACTIVE) : MODE_INACTIVE;
      });

      if (modeCopy) {
        modeCopy.textContent = accessible
          ? 'Vista accesible activa: se resaltan botones grandes, contraste alto y mensajes más evidentes.'
          : 'Vista estándar activa: se reduce el apoyo visual para mostrar por qué la propuesta accesible resulta más clara.';
      }

      if (captureModeBadge) {
        captureModeBadge.textContent = accessible ? 'Modo accesible activado' : 'Vista estándar';
      }

      if (summaryCopy) {
        summaryCopy.textContent = accessible
          ? 'Revise el pedido antes de confirmar para evitar confusiones.'
          : 'El resumen sigue presente, pero con menor énfasis visual.';
      }

      if (summaryBadge) {
        summaryBadge.textContent = accessible ? 'Revisión clara' : 'Revisión básica';
      }

      if (feature1Title) feature1Title.textContent = accessible ? 'Botones grandes' : 'Botones estándar';
      if (feature1Copy) {
        feature1Copy.textContent = accessible
          ? 'Facilitan la selección y reducen errores de pulso.'
          : 'La selección sigue siendo posible, pero requiere más precisión visual.';
      }

      if (feature2Title) feature2Title.textContent = accessible ? 'Texto visible' : 'Texto regular';
      if (feature2Copy) {
        feature2Copy.textContent = accessible
          ? 'La lectura se organiza en bloques cortos y claros.'
          : 'La información conserva el contenido, pero con menor apoyo para lectura rápida.';
      }

      if (feature3Title) feature3Title.textContent = accessible ? 'Paso único' : 'Menor apoyo guiado';
      if (feature3Copy) {
        feature3Copy.textContent = accessible
          ? 'El usuario se concentra primero en armar el pedido.'
          : 'La tarea mantiene el flujo, aunque se siente menos acompañada visualmente.';
      }

      if (modeInfo1Title) modeInfo1Title.textContent = accessible ? 'Texto y contraste' : 'Texto regular';
      if (modeInfo1Copy) {
        modeInfo1Copy.textContent = accessible
          ? 'Se evita texto pequeño y se destacan títulos, acciones y estados con contraste alto.'
          : 'La vista conserva la información, pero con menor apoyo visual para lectura rápida.';
      }

      if (modeInfo2Title) modeInfo2Title.textContent = accessible ? 'Menos pasos' : 'Guía más limitada';
      if (modeInfo2Copy) {
        modeInfo2Copy.textContent = accessible
          ? 'La interfaz divide tareas para que el usuario no tenga que decidir muchas cosas al mismo tiempo.'
          : 'La estructura sigue presente, pero con menos énfasis en acompañar cada paso.';
      }

      if (modeInfo3Title) modeInfo3Title.textContent = accessible ? 'Retroalimentación visible' : 'Retroalimentación básica';
      if (modeInfo3Copy) {
        modeInfo3Copy.textContent = accessible
          ? 'El sistema informa con claridad cuando un pedido fue registrado, impreso o entregado.'
          : 'Los mensajes existen, pero se perciben con menos fuerza dentro de la interfaz.';
      }
    }

    function setActivePanel(id) {
      tabs.forEach((tab) => {
        const active = tab.getAttribute('data-target') === id;
        tab.setAttribute('aria-selected', String(active));
        tab.setAttribute('tabindex', active ? '0' : '-1');
        tab.className = active ? TAB_ACTIVE : TAB_INACTIVE;
      });

      panels.forEach((panel) => {
        const active = panel.getAttribute('data-panel') === id;
        panel.classList.toggle('hidden', !active);
        panel.setAttribute('aria-hidden', String(!active));
      });

      const selectedStep = prototypeSteps.find((step) => step.id === id);
      if (!selectedStep) return;

      if (sideTitle) sideTitle.textContent = selectedStep.title;
      if (sideDescription) sideDescription.textContent = selectedStep.description;
      if (sideList) {
        sideList.innerHTML = selectedStep.accessibility.map((item) => `<li>${item}</li>`).join('');
      }
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-target');
        if (target) setActivePanel(target);
      });

      tab.addEventListener('keydown', (event) => {
        const currentIndex = tabs.indexOf(tab);
        if (currentIndex === -1) return;

        let nextIndex = currentIndex;

        if (event.key === 'ArrowRight') nextIndex = (currentIndex + 1) % tabs.length;
        if (event.key === 'ArrowLeft') nextIndex = (currentIndex - 1 + tabs.length) % tabs.length;
        if (event.key === 'Home') nextIndex = 0;
        if (event.key === 'End') nextIndex = tabs.length - 1;

        if (nextIndex !== currentIndex) {
          event.preventDefault();
          const nextTab = tabs[nextIndex];
          const target = nextTab?.getAttribute('data-target');
          if (nextTab && target) {
            setActivePanel(target);
            nextTab.focus();
          }
        }
      });
    });

    modeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const mode = button.getAttribute('data-mode');
        if (mode) setAccessibilityMode(mode);
      });
    });

    fontButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const size = button.getAttribute('data-font-size');
        if (size) setFontSize(size);
      });
    });

    const products = Array.from(document.querySelectorAll('.capture-product'));
    const demandButtons = Array.from(document.querySelectorAll('.demand-select'));
    const summary = document.getElementById('capture-summary');
    const errorBox = document.getElementById('capture-error');
    const recoveryBox = document.getElementById('capture-recovery');
    const successBox = document.getElementById('capture-success');
    const confirmBtn = document.getElementById('capture-confirm');
    const selectedOrder = document.getElementById('demand-selected-order');
    const selectedStatus = document.getElementById('demand-selected-status');
    const selectedDetail = document.getElementById('demand-selected-detail');
    let selectedProducts = [];

    function setDemandSelection(button) {
      demandButtons.forEach((item) => {
        const card = item.closest('.demand-card');
        card?.classList.toggle('is-active', item === button);
      });

      const order = button.getAttribute('data-order');
      const status = button.getAttribute('data-status');
      const detail = button.getAttribute('data-detail');

      if (selectedOrder && order) selectedOrder.textContent = order;
      if (selectedStatus && status) selectedStatus.textContent = `Estado: ${status}`;
      if (selectedDetail && detail) selectedDetail.textContent = `Detalle: ${detail}`;
    }

    function renderSummary() {
      if (!summary) return;

      if (selectedProducts.length === 0) {
        summary.innerHTML = '<p class="text-slate-500">Aún no hay productos seleccionados. Elija al menos uno para continuar.</p>';
        return;
      }

      summary.innerHTML = selectedProducts
        .map(
          (product) => `
            <div class="flex items-center justify-between rounded-2xl bg-[#111827] px-4 py-3">
              <span>${product}</span>
              <span>1</span>
            </div>
          `
        )
        .join('');
    }

    function updateProducts() {
      products.forEach((button) => {
        const product = button.getAttribute('data-product');
        const selected = product ? selectedProducts.includes(product) : false;
        const action = button.querySelector('.capture-action');

        button.setAttribute('aria-pressed', String(selected));
        button.classList.toggle('border-green-500/40', selected);
        button.classList.toggle('bg-green-500/15', selected);
        button.classList.toggle('hover:bg-green-500/20', selected);
        button.classList.toggle('bg-[#314158]', !selected);
        button.classList.toggle('hover:bg-[#39506d]', !selected);

        if (action) {
          action.textContent = selected ? 'Agregado' : 'Agregar';
        }
      });
    }

    products.forEach((button) => {
      button.addEventListener('click', () => {
        const product = button.getAttribute('data-product');
        if (!product) return;

        if (selectedProducts.includes(product)) {
          selectedProducts = selectedProducts.filter((item) => item !== product);
        } else {
          selectedProducts.push(product);
        }

        if (errorBox) errorBox.classList.add('hidden');
        if (recoveryBox) recoveryBox.classList.add('hidden');
        if (successBox) successBox.classList.add('hidden');
        renderSummary();
        updateProducts();
      });
    });

    demandButtons.forEach((button) => {
      button.addEventListener('click', () => {
        setDemandSelection(button);
      });
    });

    if (confirmBtn) {
      confirmBtn.addEventListener('click', () => {
        if (selectedProducts.length === 0) {
          if (errorBox) errorBox.classList.remove('hidden');
          if (recoveryBox) recoveryBox.classList.remove('hidden');
          if (successBox) successBox.classList.add('hidden');
          return;
        }

        if (errorBox) errorBox.classList.add('hidden');
        if (recoveryBox) recoveryBox.classList.add('hidden');
        if (successBox) successBox.classList.remove('hidden');
      });
    }

    renderSummary();
    updateProducts();
    setActivePanel('captura');
    setAccessibilityMode('on');
    setFontSize('base');
    if (demandButtons[1]) setDemandSelection(demandButtons[1]);
  })();
</script>
