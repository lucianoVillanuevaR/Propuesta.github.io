<section id="demo" class="py-20 text-white">
  <div class="mx-auto max-w-2xl px-6">
    <div class="mb-12 text-center">
      <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-sky-400">
        Demo interactiva
      </p>
      <h2 class="text-4xl font-bold md:text-5xl">
        Asi se veria el sistema en su modo accesible
      </h2>
      <p class="mx-auto mt-4 max-w-3xl text-slate-400">
        Simulacion de un flujo accesible pensado para facilitar la toma de pedidos con mayor claridad, menos errores y mejor comprension.
      </p>
    </div>

    <div
      id="accessible-demo"
      class="demo-shell rounded-[28px] border border-white/10 bg-[#0B1120] p-4 shadow-2xl shadow-black/25"
      data-font-size="base"
      data-accessible="on"
      data-step="1"
    >
      <div
        id="accessible-panel"
        class="demo-panel rounded-[24px] border border-sky-400/30 bg-[#0a1324] p-5 shadow-[0_0_30px_rgba(56,189,248,0.08)] transition-all duration-200"
      >
        <div class="mb-4">
          <p class="demo-kicker mb-2 text-xs font-medium uppercase tracking-[0.2em] text-sky-400">
            Modo accesible activado
          </p>
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="demo-muted text-sm text-slate-400">Demo del sistema</p>
              <h3 class="demo-title text-2xl font-semibold text-white">
                Ingreso de pedido accesible
              </h3>
            </div>
            <span
              id="accessible-badge"
              class="demo-chip rounded-full bg-green-500/15 px-3 py-1 text-xs font-medium text-green-400"
            >
              Interfaz accesible
            </span>
          </div>
        </div>

        <div class="mb-5 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <button
            id="toggle-accessible"
            type="button"
            aria-pressed="true"
            class="demo-toggle rounded-full border border-green-400/20 bg-green-500/10 px-4 py-2 text-sm font-medium text-green-300 transition hover:bg-green-500/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-300 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a1324]"
          >
            Modo accesible: ON
          </button>

          <div
            class="flex flex-wrap items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-2"
            role="group"
            aria-label="Tamano de texto"
          >
            <span class="text-xs text-slate-400">Texto</span>
            <button
              type="button"
              data-font="sm"
              aria-pressed="false"
              class="font-btn rounded-full bg-[#111827] px-3 py-1 text-sm text-white transition hover:bg-[#1f2937] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-300"
            >
              A-
            </button>
            <button
              type="button"
              data-font="base"
              aria-pressed="true"
              class="font-btn rounded-full bg-[#1f2937] px-3 py-1 text-sm text-white transition hover:bg-[#1f2937] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-300"
            >
              A
            </button>
            <button
              type="button"
              data-font="lg"
              aria-pressed="false"
              class="font-btn rounded-full bg-[#111827] px-3 py-1 text-sm text-white transition hover:bg-[#1f2937] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-300"
            >
              A+
            </button>
          </div>
        </div>

        <div class="mb-5 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-[#111827] p-4">
            <p class="demo-card-title text-sm font-medium text-white">Botones grandes</p>
            <p class="demo-muted mt-1 text-sm text-slate-400">Facilitan la seleccion sin errores.</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-[#111827] p-4">
            <p class="demo-card-title text-sm font-medium text-white">Lectura clara</p>
            <p class="demo-muted mt-1 text-sm text-slate-400">Texto visible y jerarquia comprensible.</p>
          </div>
        </div>

        <div class="rounded-3xl border border-white/10 bg-[#020617] p-4">
          <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="demo-kicker text-xs uppercase tracking-wide text-slate-500">Pedido actual</p>
              <p id="step-label" class="demo-title text-base font-semibold text-white">Paso 1 de 2 - Selecciona productos</p>
            </div>
            <span class="demo-chip rounded-full bg-sky-500/15 px-3 py-1 text-xs text-sky-300">
              Guiado
            </span>
          </div>

          <p id="help-text" class="demo-muted mb-4 text-sm text-slate-400">
            Modo accesible activo: mayor contraste, botones grandes y lectura mas clara.
          </p>

          <div id="product-list" class="space-y-3" role="list" aria-label="Productos disponibles">
            <button
              type="button"
              data-product="Hamburguesa"
              aria-pressed="false"
              class="product-btn group flex w-full items-center justify-between gap-4 rounded-2xl border border-white/10 bg-[#334155] px-4 py-4 text-left transition hover:bg-[#3b4a61] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-300 focus-visible:ring-offset-2 focus-visible:ring-offset-[#020617]"
            >
              <span class="flex min-w-0 items-center gap-3">
                <span class="text-2xl" aria-hidden="true">🍔</span>
                <span class="min-w-0">
                  <span class="demo-title block text-base font-semibold text-white">Hamburguesa</span>
                  <span class="demo-muted block text-sm text-slate-300">Seleccion rapida</span>
                </span>
              </span>
              <span class="product-action shrink-0 text-sm text-slate-100">Agregar al pedido</span>
            </button>

            <button
              type="button"
              data-product="Bebida"
              aria-pressed="false"
              class="product-btn group flex w-full items-center justify-between gap-4 rounded-2xl border border-white/10 bg-[#334155] px-4 py-4 text-left transition hover:bg-[#3b4a61] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-300 focus-visible:ring-offset-2 focus-visible:ring-offset-[#020617]"
            >
              <span class="flex min-w-0 items-center gap-3">
                <span class="text-2xl" aria-hidden="true">🥤</span>
                <span class="min-w-0">
                  <span class="demo-title block text-base font-semibold text-white">Bebida</span>
                  <span class="demo-muted block text-sm text-slate-300">Opcion complementaria</span>
                </span>
              </span>
              <span class="product-action shrink-0 text-sm text-slate-100">Agregar al pedido</span>
            </button>
          </div>

          <div
            id="error-box"
            class="mt-4 hidden rounded-2xl border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-200"
            role="alert"
          >
            Debes seleccionar al menos un producto antes de confirmar.
          </div>

          <div class="mt-5 rounded-2xl border border-white/10 bg-[#0B1120] p-4">
            <div class="mb-3 flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="demo-card-title text-sm font-medium text-white">Resumen claro del pedido</p>
                <p class="demo-muted mt-1 text-sm text-slate-400">
                  Pedido facil de revisar antes de confirmar.
                </p>
              </div>
              <span id="status-pill" class="demo-chip rounded-full bg-green-500/15 px-3 py-1 text-xs font-medium text-green-400">
                Sin errores
              </span>
            </div>

            <div id="summary-list" class="demo-summary space-y-2 text-sm text-slate-200" aria-live="polite">
              <p class="text-slate-500">Aun no hay productos seleccionados.</p>
            </div>

            <button
              id="confirm-btn"
              type="button"
              class="mt-5 w-full rounded-2xl bg-green-500 px-4 py-4 text-base font-semibold text-slate-950 transition hover:bg-green-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-green-300 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0B1120]"
              style="box-shadow: 0 0 20px rgba(34, 197, 94, 0.3);"
            >
              Confirmar pedido
            </button>

            <div
              id="success-box"
              class="mt-4 hidden rounded-2xl border border-green-500/20 bg-green-500/10 px-4 py-3 text-sm text-green-200"
              role="status"
              aria-live="polite"
            >
              Pedido registrado correctamente.
            </div>
          </div>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl border border-white/10 bg-[#111827] p-4">
            <p class="demo-card-title text-sm font-semibold text-white">Menos pasos</p>
            <p class="demo-muted mt-1 text-xs text-slate-400">Reduce complejidad y tiempo.</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-[#111827] p-4">
            <p class="demo-card-title text-sm font-semibold text-white">Apoyo visual</p>
            <p class="demo-muted mt-1 text-xs text-slate-400">Estados y acciones faciles de entender.</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-[#111827] p-4">
            <p class="demo-card-title text-sm font-semibold text-white">Uso inclusivo</p>
            <p class="demo-muted mt-1 text-xs text-slate-400">Disenado para una mayor diversidad de usuarios.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #accessible-demo[data-font-size='sm'] .demo-title,
  #accessible-demo[data-font-size='sm'] .demo-card-title {
    font-size: 0.98rem;
  }

  #accessible-demo[data-font-size='sm'] .demo-muted,
  #accessible-demo[data-font-size='sm'] .demo-summary,
  #accessible-demo[data-font-size='sm'] .product-action,
  #accessible-demo[data-font-size='sm'] .demo-toggle,
  #accessible-demo[data-font-size='sm'] .demo-chip {
    font-size: 0.84rem;
  }

  #accessible-demo[data-font-size='lg'] .demo-title,
  #accessible-demo[data-font-size='lg'] .demo-card-title {
    font-size: 1.16rem;
    line-height: 1.45;
  }

  #accessible-demo[data-font-size='lg'] .demo-muted,
  #accessible-demo[data-font-size='lg'] .demo-summary,
  #accessible-demo[data-font-size='lg'] .product-action,
  #accessible-demo[data-font-size='lg'] .demo-toggle,
  #accessible-demo[data-font-size='lg'] .demo-chip {
    font-size: 1rem;
    line-height: 1.6;
  }

  #accessible-demo[data-font-size='lg'] .product-btn {
    padding-top: 1.25rem;
    padding-bottom: 1.25rem;
  }

  #accessible-demo[data-font-size='lg'] #product-list,
  #accessible-demo[data-font-size='lg'] .demo-summary {
    row-gap: 0.85rem;
  }

  #accessible-demo[data-accessible='off'] #accessible-panel {
    border-color: rgba(148, 163, 184, 0.18);
    box-shadow: none;
  }

  #accessible-demo[data-accessible='off'] .product-btn {
    background: #273449;
  }

  #accessible-demo[data-accessible='off'] #help-text {
    color: #94a3b8;
  }

  @media (max-width: 640px) {
    #accessible-demo .product-btn {
      align-items: flex-start;
      flex-direction: column;
    }

    #accessible-demo .product-action {
      padding-left: 2.75rem;
    }
  }
</style>

<script>
  (() => {
    const demo = document.getElementById('accessible-demo');
    if (!demo) return;

    const toggleAccessible = document.getElementById('toggle-accessible');
    const accessibleBadge = document.getElementById('accessible-badge');
    const accessiblePanel = document.getElementById('accessible-panel');
    const stepLabel = document.getElementById('step-label');
    const helpText = document.getElementById('help-text');
    const productButtons = Array.from(document.querySelectorAll('.product-btn'));
    const summaryList = document.getElementById('summary-list');
    const confirmBtn = document.getElementById('confirm-btn');
    const successBox = document.getElementById('success-box');
    const errorBox = document.getElementById('error-box');
    const fontButtons = Array.from(document.querySelectorAll('.font-btn'));

    let selectedProducts = [];
    let accessibleMode = true;

    function renderSummary() {
      if (!summaryList) return;

      if (selectedProducts.length === 0) {
        summaryList.innerHTML = '<p class="text-slate-500">Aun no hay productos seleccionados.</p>';
        if (stepLabel) stepLabel.textContent = 'Paso 1 de 2 - Selecciona productos';
        return;
      }

      if (stepLabel) stepLabel.textContent = 'Paso 2 de 2 - Revisa y confirma';
      summaryList.innerHTML = selectedProducts
        .map(
          (product) => `
            <div class="flex justify-between gap-4">
              <span>${product}</span>
              <span>1</span>
            </div>
          `
        )
        .join('');
    }

    function updateProductStyles() {
      productButtons.forEach((btn) => {
        const product = btn.getAttribute('data-product');
        const action = btn.querySelector('.product-action');
        const isSelected = product ? selectedProducts.includes(product) : false;

        btn.classList.toggle('border-green-500/50', isSelected);
        btn.classList.toggle('bg-green-500/20', isSelected);
        btn.classList.toggle('hover:bg-green-500/25', isSelected);
        btn.classList.toggle('bg-[#334155]', !isSelected);
        btn.classList.toggle('hover:bg-[#3b4a61]', !isSelected);
        btn.classList.toggle('ring-2', isSelected);
        btn.classList.toggle('ring-green-400/20', isSelected);
        btn.setAttribute('aria-pressed', String(isSelected));

        if (action) {
          action.textContent = isSelected ? 'Agregado' : 'Agregar al pedido';
        }
      });
    }

    function setAccessibleMode(on) {
      accessibleMode = on;
      demo.dataset.accessible = on ? 'on' : 'off';

      if (toggleAccessible) {
        toggleAccessible.textContent = on ? 'Modo accesible: ON' : 'Modo accesible: OFF';
        toggleAccessible.setAttribute('aria-pressed', String(on));
        toggleAccessible.className = on
          ? 'demo-toggle rounded-full border border-green-400/20 bg-green-500/10 px-4 py-2 text-sm font-medium text-green-300 transition hover:bg-green-500/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-300 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a1324]'
          : 'demo-toggle rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-white transition hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-300 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a1324]';
      }

      if (accessibleBadge) {
        accessibleBadge.textContent = on ? 'Interfaz accesible' : 'Vista estandar';
      }

      if (helpText) {
        helpText.textContent = on
          ? 'Modo accesible activo: mayor contraste, botones grandes y lectura mas clara.'
          : 'Vista estandar: mantiene el flujo simple, pero con menos apoyo visual.';
      }

      if (accessiblePanel) {
        accessiblePanel.classList.toggle('ring-2', on);
        accessiblePanel.classList.toggle('ring-sky-400/20', on);
      }
    }

    function setFontSize(size) {
      demo.dataset.fontSize = size;

      fontButtons.forEach((btn) => {
        const isActive = btn.getAttribute('data-font') === size;
        btn.setAttribute('aria-pressed', String(isActive));
        btn.classList.toggle('bg-[#1f2937]', isActive);
        btn.classList.toggle('bg-[#111827]', !isActive);
      });
    }

    productButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const product = btn.getAttribute('data-product');
        if (!product) return;

        if (selectedProducts.includes(product)) {
          selectedProducts = selectedProducts.filter((item) => item !== product);
        } else {
          selectedProducts.push(product);
        }

        if (successBox) successBox.classList.add('hidden');
        if (errorBox) errorBox.classList.add('hidden');

        renderSummary();
        updateProductStyles();
      });
    });

    fontButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const size = btn.getAttribute('data-font');
        setFontSize(size || 'base');
      });
    });

    if (toggleAccessible) {
      toggleAccessible.addEventListener('click', () => {
        setAccessibleMode(!accessibleMode);
      });
    }

    if (confirmBtn) {
      confirmBtn.addEventListener('click', () => {
        if (selectedProducts.length === 0) {
          if (errorBox) errorBox.classList.remove('hidden');
          if (successBox) successBox.classList.add('hidden');
          return;
        }

        if (errorBox) errorBox.classList.add('hidden');
        if (successBox) successBox.classList.remove('hidden');
      });
    }

    renderSummary();
    updateProductStyles();
    setFontSize('base');
    setAccessibleMode(true);
  })();
</script>
