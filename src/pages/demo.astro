---
import InteractiveDemo from '../components/InteractiveDemo.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollToTopButton from '../components/ScrollToTopButton.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Demo interactiva del sistema accesible"
  description="Demo interactiva del sistema web de gestión de pedidos con enfoque en accesibilidad."
>
  <div class="min-h-screen">
    <header class="sticky top-0 z-10 border-b border-white/8 bg-[#0f172acc] backdrop-blur-xl">
      <div class="mx-auto flex w-[min(calc(100%-2rem),1180px)] items-center justify-between py-4">
        <a
          href="/Propuesta.github.io/"
          class="font-display text-base font-bold tracking-[-0.03em] text-slate-50"
        >
          Sistema de pedidos accesible
        </a>

        <a
          href="/Propuesta.github.io/"
          class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-slate-200 transition hover:bg-white/10"
        >
          Volver a la página principal
        </a>
      </div>
    </header>

    <main class="pt-6">
      <InteractiveDemo />
    </main>

    <ScrollToTopButton id="scroll-to-top-demo" />
  </div>
</BaseLayout>
