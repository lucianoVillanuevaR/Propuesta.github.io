---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const sections = [
  { id: 'hero', label: 'Inicio' },
  { id: 'problema', label: 'Problema' },
  { id: 'solucion', label: 'Solucion' },
  { id: 'accesibilidad', label: 'Accesibilidad' },
  { id: 'funcionalidades', label: 'Funciones' },
  { id: 'impacto', label: 'Impacto' },
  { id: 'estado', label: 'Estado' },
];

const heroHighlights = [
  'Registro digital de pedidos presenciales',
  'Seguimiento claro del flujo de atencion',
  'Diseno accesible para adultos mayores',
];

const heroStats = [
  { label: 'Enfoque principal', value: 'Accesibilidad real' },
  { label: 'Contexto', value: 'Pyme gastronomica' },
  { label: 'Operacion', value: 'Uso interno en local' },
];

const problemFlow = [
  'El pedido se recibe de forma presencial o desde plataformas de delivery.',
  'La informacion se anota manualmente en comandas o en un block de notas.',
  'La preparacion y entrega dependen de ese registro manual para continuar.',
];

const problemIssues = [
  {
    title: 'Errores de registro',
    description: 'La escritura manual aumenta el riesgo de errores, confusiones e interpretaciones incorrectas.',
  },
  {
    title: 'Perdida de informacion',
    description: 'Sin un sistema centralizado, los pedidos pueden perderse, duplicarse o quedar incompletos.',
  },
  {
    title: 'Desorganizacion operativa',
    description: 'En alta demanda se vuelve mas dificil mantener el orden de preparacion y entrega.',
  },
  {
    title: 'Sobrecarga al atender',
    description: 'Quien atiende debe dividir su atencion entre anotar, coordinar y entregar, reduciendo eficiencia.',
  },
];
---

<BaseLayout
  title="Sistema web de gestion de pedidos accesible"
  description="Landing page del proyecto de titulo sobre gestion de pedidos accesible para pymes del rubro gastronomico."
>
  <div class="relative overflow-hidden">
    <div class="pointer-events-none absolute top-[120px] left-[-140px] z-0 h-80 w-80 rounded-full bg-blue-600/8 blur-lg"></div>
    <div class="pointer-events-none absolute top-[520px] right-[-120px] z-0 h-72 w-72 rounded-full bg-sky-500/8 blur-lg"></div>

    <header class="sticky top-0 z-10 border-b border-slate-900/5 bg-[rgba(244,247,251,0.72)] backdrop-blur-xl">
      <div class="relative z-[1] mx-auto flex w-[min(calc(100%-2rem),1180px)] flex-col items-start justify-between gap-5 py-4 lg:flex-row lg:items-center">
        <a
          class="inline-flex items-center gap-3.5 font-display text-base font-bold tracking-[-0.03em] text-slate-900"
          href="#hero"
          aria-label="Ir al inicio del proyecto"
        >
          <span class="grid h-11 w-11 place-items-center rounded-2xl bg-linear-to-br from-blue-600 to-sky-500 font-display text-base font-bold text-white shadow-[0_12px_30px_rgba(37,99,235,0.28)]">LV</span>
          <span>Sistema de pedidos accesible</span>
        </a>

        <nav class="flex flex-wrap justify-end gap-2" aria-label="Secciones principales">
          {
            sections.map((section) => (
              <a
                class="rounded-full px-4 py-3 text-[0.96rem] text-slate-500 transition hover:bg-white/70 hover:text-slate-900 focus-visible:bg-white/70 focus-visible:text-slate-900"
                href={`#${section.id}`}
              >
                {section.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main>
      <section class="px-0 pt-12 pb-18 sm:pt-16 sm:pb-18" id="hero">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="rounded-[32px] border border-[rgba(15,23,42,0.08)] bg-white/78 p-6 shadow-soft backdrop-blur-xl md:p-8 lg:p-10">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)] lg:items-center">
              <div class="grid max-w-[42rem] gap-5">
                <span class="inline-flex w-fit items-center gap-2 rounded-full bg-blue-600/12 px-3.5 py-2 text-[0.88rem] font-bold text-blue-700 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">
                  Proyecto de titulo 2026
                </span>

                <div class="grid gap-4">
                  <h1 class="m-0 max-w-[11ch] text-[clamp(3.3rem,8vw,6.1rem)] leading-[0.95] font-extrabold tracking-[-0.055em] text-slate-950">
                    Pedidos claros, atencion sin friccion.
                  </h1>
                  <p class="m-0 max-w-[40rem] text-[1.08rem] leading-7 text-slate-500 sm:text-[1.12rem] sm:leading-8">
                    Sistema web de gestion de pedidos para pymes del rubro gastronomico,
                    disenado para digitalizar el registro manual y facilitar su uso a personas
                    con baja alfabetizacion digital, incluyendo adultos mayores.
                  </p>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row">
                  <a
                    class="inline-flex items-center justify-center rounded-full bg-slate-950 px-6 py-3.5 text-sm font-bold text-white transition hover:bg-blue-700"
                    href="#solucion"
                  >
                    Ver proyecto
                  </a>
                  <a
                    class="inline-flex items-center justify-center rounded-full border border-slate-900/10 bg-white/80 px-6 py-3.5 text-sm font-bold text-slate-700 transition hover:border-blue-200 hover:text-blue-700"
                    href="#problema"
                  >
                    Conocer mas
                  </a>
                </div>

                <div class="grid gap-3 pt-2">
                  {
                    heroHighlights.map((item) => (
                      <div class="flex items-start gap-3 text-slate-600">
                        <span class="mt-1.5 h-2.5 w-2.5 rounded-full bg-blue-600"></span>
                        <span class="text-[0.98rem] leading-7">{item}</span>
                      </div>
                    ))
                  }
                </div>
              </div>

              <div class="relative">
                <div class="absolute inset-x-8 top-6 h-24 rounded-full bg-blue-500/12 blur-3xl"></div>
                <div class="relative overflow-hidden rounded-[30px] border border-slate-900/8 bg-slate-950 p-5 text-white shadow-[0_28px_80px_rgba(15,23,42,0.22)]">
                  <div class="mb-5 flex items-center justify-between">
                    <div>
                      <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Sistema interno</p>
                      <h3 class="mt-2 text-2xl leading-tight font-bold tracking-[-0.04em]">
                        Flujo de pedidos accesible
                      </h3>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-white/5 px-3 py-2 text-right">
                      <p class="text-[0.68rem] uppercase tracking-[0.24em] text-slate-400">Estado</p>
                      <p class="mt-1 text-sm font-semibold text-emerald-300">Propuesta definida</p>
                    </div>
                  </div>

                  <div class="grid gap-3">
                    <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
                      <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Pedido activo</p>
                      <p class="mt-2 text-lg font-semibold">Hamburguesa + bebida + papas</p>
                      <p class="mt-1 text-sm text-slate-300">Ingreso rapido, lectura simple y pasos reducidos.</p>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-3">
                      {
                        heroStats.map((stat) => (
                          <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
                            <p class="text-xs uppercase tracking-[0.2em] text-slate-400">{stat.label}</p>
                            <p class="mt-3 text-sm leading-6 font-semibold text-white">{stat.value}</p>
                          </div>
                        ))
                      }
                    </div>

                    <div class="rounded-3xl border border-blue-400/20 bg-blue-500/10 p-4">
                      <p class="text-xs uppercase tracking-[0.24em] text-blue-200">Objetivo</p>
                      <p class="mt-2 text-sm leading-7 text-slate-200">
                        Reducir errores, ordenar la operacion diaria y mejorar la adopcion
                        tecnologica dentro del negocio.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="problema">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(320px,1.08fr)] lg:items-start">
            <div class="grid gap-5">
              <div class="grid max-w-[42rem] gap-3.5">
                <span class="inline-flex w-fit items-center gap-2 rounded-full bg-blue-600/12 px-3.5 py-2 text-[0.88rem] font-bold text-blue-700 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Problema</span>
                <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-950">
                  Cuando todo depende del papel, el ritmo se rompe.
                </h2>
                <p class="m-0 max-w-[38rem] text-[1.05rem] leading-7 text-slate-500 sm:leading-8">
                  Segun la propuesta, la gestion actual de pedidos se realiza de manera manual.
                  Esto sostiene la operacion diaria, pero genera errores, perdida de informacion
                  y desorden, especialmente en momentos de alta demanda.
                </p>
              </div>

              <div class="rounded-[28px] border border-slate-900/8 bg-white/72 p-6">
                <div class="mb-4 flex items-center justify-between gap-4">
                  <div>
                    <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Proceso actual</p>
                    <h3 class="mt-2 text-2xl leading-tight font-bold tracking-[-0.04em] text-slate-950">
                      Flujo manual de atencion
                    </h3>
                  </div>
                  <span class="rounded-full border border-amber-300/50 bg-amber-100 px-3 py-1 text-xs font-bold text-amber-700">
                    Alto riesgo en horas punta
                  </span>
                </div>

                <div class="grid gap-4">
                  {
                    problemFlow.map((step, index) => (
                      <div class="flex gap-4 rounded-3xl border border-slate-900/6 bg-slate-50/80 p-4">
                        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-slate-950 text-sm font-bold text-white">
                          0{index + 1}
                        </span>
                        <p class="m-0 text-[0.98rem] leading-7 text-slate-600">{step}</p>
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              {
                problemIssues.map((item) => (
                  <article class="rounded-[28px] border border-slate-900/8 bg-white/72 p-6 shadow-[0_18px_60px_rgba(15,23,42,0.06)]">
                    <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl bg-red-500/10 text-sm font-bold text-red-600">
                      !
                    </div>
                    <h3 class="text-xl leading-tight font-bold tracking-[-0.04em] text-slate-950">
                      {item.title}
                    </h3>
                    <p class="mt-3 text-[0.98rem] leading-7 text-slate-500">
                      {item.description}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="solucion">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid max-w-[42rem] gap-3.5">
            <span class="inline-flex w-fit items-center gap-2 rounded-full bg-blue-600/12 px-3.5 py-2 text-[0.88rem] font-bold text-blue-700 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Solucion</span>
            <h2 class="m-0 text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-950">Espacio preparado para presentar el sistema propuesto</h2>
            <p class="m-0 text-[1.05rem] leading-7 text-slate-500 sm:leading-8">
              Esta seccion recibira el resumen del sistema web interno, el seguimiento de
              pedidos y la integracion con impresion de comandas.
            </p>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="accesibilidad">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid max-w-[42rem] gap-3.5">
            <span class="inline-flex w-fit items-center gap-2 rounded-full bg-blue-600/12 px-3.5 py-2 text-[0.88rem] font-bold text-blue-700 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Diferenciador</span>
            <h2 class="m-0 text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-950">Seccion reservada para accesibilidad y facilidad de uso</h2>
            <p class="m-0 text-[1.05rem] leading-7 text-slate-500 sm:leading-8">
              La base ya contempla una composicion amplia y limpia para destacar interfaz
              simple, botones grandes y apoyo visual en proximas partes.
            </p>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="funcionalidades">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="mb-8 grid max-w-[42rem] gap-3.5">
            <span class="inline-flex w-fit items-center gap-2 rounded-full bg-blue-600/12 px-3.5 py-2 text-[0.88rem] font-bold text-blue-700 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Funcionalidades</span>
            <h2 class="m-0 text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-950">Grid preparado para tarjetas del sistema</h2>
            <p class="m-0 text-[1.05rem] leading-7 text-slate-500 sm:leading-8">
              Dejamos lista la estructura que luego usaremos para registro de pedidos,
              historial, inventario y visualizacion en curso.
            </p>
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            <article class="rounded-3xl border border-slate-900/8 bg-white/72 p-6">
              <h3 class="mb-3 text-xl leading-tight font-bold tracking-[-0.045em] text-slate-950">Tarjeta 01</h3>
              <p class="max-w-[34rem] text-[1.05rem] leading-7 text-slate-500">Base lista para contenido funcional resumido y visual.</p>
            </article>
            <article class="rounded-3xl border border-slate-900/8 bg-white/72 p-6">
              <h3 class="mb-3 text-xl leading-tight font-bold tracking-[-0.045em] text-slate-950">Tarjeta 02</h3>
              <p class="max-w-[34rem] text-[1.05rem] leading-7 text-slate-500">La grilla ya es responsive y mantiene la coherencia del layout.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="impacto">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid max-w-[42rem] gap-3.5">
            <span class="inline-flex w-fit items-center gap-2 rounded-full bg-blue-600/12 px-3.5 py-2 text-[0.88rem] font-bold text-blue-700 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Impacto</span>
            <h2 class="m-0 text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-950">Bloque listo para beneficios y resultados esperados</h2>
            <p class="m-0 text-[1.05rem] leading-7 text-slate-500 sm:leading-8">
              En esta parte mostraremos reduccion de errores, mejora en tiempos de atencion,
              organizacion interna e inclusion digital.
            </p>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="estado">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid max-w-[42rem] gap-3.5">
            <span class="inline-flex w-fit items-center gap-2 rounded-full bg-blue-600/12 px-3.5 py-2 text-[0.88rem] font-bold text-blue-700 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Estado del proyecto</span>
            <h2 class="m-0 text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-950">Estructura preparada para avances y proxima evaluacion</h2>
            <p class="m-0 text-[1.05rem] leading-7 text-slate-500 sm:leading-8">
              La propuesta, el diseno, el desarrollo y la validacion con usuarios se iran
              incorporando paso a paso sobre esta misma base.
            </p>
          </div>
        </div>
      </section>
    </main>

    <footer class="px-0 pt-8 pb-16">
      <div class="relative z-[1] mx-auto flex w-[min(calc(100%-2rem),1180px)] flex-col items-start justify-between gap-4 border-t border-slate-900/8 pt-6 text-[0.95rem] text-slate-500 lg:flex-row">
        <span>Luciano Villanueva Ramirez</span>
        <span>Ingenieria en Ejecucion en Computacion e Informatica</span>
        <span>Universidad del Bio-Bio</span>
      </div>
    </footer>
  </div>
</BaseLayout>
