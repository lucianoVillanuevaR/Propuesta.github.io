---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const sections = [
  { id: 'inicio', label: 'Inicio' },
  { id: 'problema', label: 'Problema' },
  { id: 'solucion', label: 'Solucion' },
  { id: 'demo', label: 'Demo' },
  { id: 'funciones', label: 'Funciones' },
  { id: 'impacto', label: 'Impacto' },
  { id: 'estado', label: 'Estado' },
];

const heroHighlights = [
  'Interfaz clara para usuarios con baja experiencia tecnologica',
  'Botones grandes, menos pasos y apoyo visual',
  'Registro y seguimiento digital de pedidos en tiempo real',
];

const heroStats = [
  { label: 'Enfoque principal', value: 'Accesibilidad real' },
  { label: 'Contexto', value: 'Pyme gastronomica' },
  { label: 'Operacion', value: 'Uso interno en local' },
];

const problemFlow = [
  'El pedido se recibe de forma presencial o desde plataformas de delivery.',
  'La informacion se anota manualmente en comandas o en un block de notas.',
  'La preparacion y entrega dependen de ese registro manual para continuar.',
];

const problemIssues = [
  {
    title: 'Errores de registro',
    description: 'La escritura manual aumenta el riesgo de errores, confusiones e interpretaciones incorrectas.',
  },
  {
    title: 'Perdida de informacion',
    description: 'Sin un sistema centralizado, los pedidos pueden perderse, duplicarse o quedar incompletos.',
  },
  {
    title: 'Desorganizacion operativa',
    description: 'En alta demanda se vuelve mas dificil mantener el orden de preparacion y entrega.',
  },
  {
    title: 'Sobrecarga al atender',
    description: 'Quien atiende debe dividir su atencion entre anotar, coordinar y entregar, reduciendo eficiencia.',
  },
];

const solutionSteps = [
  'Ingreso rapido de pedidos desde una interfaz web interna y clara.',
  'Registro automatico para mantener seguimiento en tiempo real.',
  'Organizacion del flujo de preparacion y entrega en un mismo sistema.',
  'Envio de comandas a impresion para mejorar la coordinacion con cocina.',
];

const solutionBenefits = [
  {
    title: 'Registro digital',
    description: 'Reemplaza la toma manual por una plataforma de uso interno orientada al trabajo diario del local.',
  },
  {
    title: 'Seguimiento en tiempo real',
    description: 'Cada pedido queda registrado automaticamente para mantener control claro de lo que esta en curso.',
  },
  {
    title: 'Operacion mas ordenada',
    description: 'Ayuda a mantener la secuencia de preparacion y entrega con menos confusion entre tareas.',
  },
  {
    title: 'Impresion de comandas',
    description: 'Integra el sistema con impresoras para enviar pedidos al area de cocina de forma automatica.',
  },
];

const impacts = [
  'Reduccion de errores en la toma de pedidos.',
  'Mejora en los tiempos de atencion y coordinacion interna.',
  'Mayor organizacion del negocio durante horas de alta demanda.',
  'Inclusion digital para usuarios con baja experiencia tecnologica.',
];

const statusItems = [
  {
    phase: 'Propuesta definida',
    description: 'El problema, los objetivos y el alcance del sistema ya fueron establecidos en el proyecto de titulo.',
  },
  {
    phase: 'Diseno en progreso',
    description: 'La interfaz se desarrolla con foco en simplicidad, accesibilidad y uso real dentro del local.',
  },
  {
    phase: 'Desarrollo proximo',
    description: 'La siguiente etapa considera implementar el sistema web, la logica de pedidos y el almacenamiento de datos.',
  },
  {
    phase: 'Evaluacion con usuarios',
    description: 'Se contemplan pruebas con usuarios reales, incluyendo adultos mayores, para validar facilidad de uso y adopcion.',
  },
];

const footerMeta = [
  'Luciano Villanueva Ramirez',
  'Ingenieria en Ejecucion en Computacion e Informatica',
  'Universidad del Bio-Bio',
];
---

<BaseLayout
  title="Sistema web de gestion de pedidos accesible"
  description="Landing page del proyecto de titulo sobre gestion de pedidos accesible para pymes del rubro gastronomico."
>
  <div class="relative overflow-hidden">
    <header class="sticky top-0 z-10 border-b border-white/8 bg-[#0f172acc] backdrop-blur-xl">
      <div class="relative z-[1] mx-auto flex w-[min(calc(100%-2rem),1180px)] flex-col items-start justify-between gap-5 py-4 lg:flex-row lg:items-center">
        <a
          class="inline-flex items-center gap-3.5 font-display text-base font-bold tracking-[-0.03em] text-slate-50"
          href="#inicio"
          aria-label="Ir al inicio del proyecto"
        >
          <span>Sistema de pedidos accesible</span>
        </a>

        <nav class="flex flex-wrap justify-end gap-2" aria-label="Secciones principales">
          {
            sections.map((section) => (
              <a
                class="rounded-full px-4 py-3 text-[0.96rem] text-slate-400 transition hover:bg-white/8 hover:text-slate-50 focus-visible:bg-white/8 focus-visible:text-slate-50"
                href={`#${section.id}`}
              >
                {section.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main>
      <section id="inicio" class="relative overflow-hidden text-white">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(56,189,248,0.08),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(34,197,94,0.06),transparent_30%)]"></div>

        <div class="relative mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-28">
          <div class="max-w-4xl">
            <p class="mb-4 inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-1 text-sm text-sky-300">
              Proyecto de titulo · Sistema web accesible
            </p>

            <p class="mb-4 text-sm font-medium text-sky-400 md:text-base">
              Disenado para personas reales, no expertos en tecnologia
            </p>

            <h1 class="max-w-4xl text-4xl font-bold leading-tight md:text-6xl">
              Sistema de gestion de pedidos
              <span class="text-sky-400"> accesible</span>
              para pymes gastronomicas
            </h1>

            <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
              Interfaz clara, comprensible y facil de usar, disenada para adultos mayores
              y personas con baja experiencia digital.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
              <a
                href="#demo"
                class="rounded-full bg-green-500 px-6 py-3 font-semibold text-slate-950 transition hover:bg-green-400"
              >
                Ver como funciona
              </a>

              <a
                href="#demo"
                class="rounded-full border border-white/15 bg-white/5 px-6 py-3 font-semibold text-white transition hover:bg-white/10"
              >
                Ver accesibilidad aplicada
              </a>
            </div>

            <div class="mt-5 flex flex-col gap-2 text-sm text-slate-400 sm:flex-row sm:flex-wrap sm:gap-5">
              <span>+ Facil de aprender en minutos</span>
              <span>+ Reduce errores en pedidos</span>
              <span>+ Mejora la organizacion del local</span>
            </div>

            <div class="mt-10 grid gap-4 md:grid-cols-3">
              <div class="rounded-2xl border border-white/10 bg-[#0B1120] p-5 transition hover:border-sky-400/30">
                <p class="text-sm font-semibold text-white">Interfaz simplificada</p>
                <p class="mt-2 text-sm text-slate-400">
                  Menos pasos y menos decisiones por accion.
                </p>
              </div>

              <div class="rounded-2xl border border-white/10 bg-[#0B1120] p-5 transition hover:border-sky-400/30">
                <p class="text-sm font-semibold text-white">Pensado para baja experiencia digital</p>
                <p class="mt-2 text-sm text-slate-400">
                  Uso facil para adultos mayores y nuevos usuarios.
                </p>
              </div>

              <div class="rounded-2xl border border-white/10 bg-[#0B1120] p-5 transition hover:border-sky-400/30">
                <p class="text-sm font-semibold text-white">Estado visible en todo momento</p>
                <p class="mt-2 text-sm text-slate-400">
                  El usuario siempre sabe que esta pasando.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="problema">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(320px,1.08fr)] lg:items-start">
            <div class="grid gap-5">
              <div class="grid max-w-[42rem] gap-3.5">
                <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Problema</span>
                <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-50">
                  Cuando todo depende del papel, el ritmo se rompe.
                </h2>
                <p class="m-0 max-w-[38rem] text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                  Segun la propuesta, la gestion actual de pedidos se realiza de manera manual.
                  Esto sostiene la operacion diaria, pero genera errores, perdida de informacion
                  y desorden, especialmente en momentos de alta demanda.
                </p>
                <p class="m-0 max-w-[38rem] text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                  Ademas del desorden operativo, la empresa necesita una solucion que pueda
                  ser utilizada por personas con distintos niveles de manejo tecnologico,
                  especialmente adultos mayores o usuarios con baja alfabetizacion digital.
                </p>
              </div>

              <div class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6">
                <div class="mb-4 flex items-center justify-between gap-4">
                  <div>
                    <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Proceso actual</p>
                    <h3 class="mt-2 text-2xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
                      Flujo manual de atencion
                    </h3>
                  </div>
                  <span class="rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1 text-xs font-bold text-amber-300">
                    Alto riesgo en horas punta
                  </span>
                </div>

                <div class="grid gap-4">
                  {
                    problemFlow.map((step, index) => (
                      <div class="flex gap-4 rounded-3xl border border-white/8 bg-white/4 p-4">
                        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-slate-50 text-sm font-bold text-slate-950">
                          0{index + 1}
                        </span>
                        <p class="m-0 text-[0.98rem] leading-7 text-slate-300">{step}</p>
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              {
                problemIssues.map((item) => (
                  <article class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6 shadow-[0_18px_60px_rgba(2,6,23,0.28)]">
                    <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl bg-cyan-400/10 text-sm font-bold text-cyan-300">
                      !
                    </div>
                    <h3 class="text-xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
                      {item.title}
                    </h3>
                    <p class="mt-3 text-[0.98rem] leading-7 text-slate-400">
                      {item.description}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="solucion">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,0.98fr)_minmax(320px,1.02fr)] lg:items-start">
            <div class="grid gap-5">
              <div class="grid max-w-[44rem] gap-3.5">
                <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Solucion</span>
                <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-50">
                  Un sistema interno para ordenar cada pedido desde el primer clic.
                </h2>
                <p class="m-0 max-w-[40rem] text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                  La propuesta plantea un sistema web de uso interno para registrar pedidos
                  presenciales, hacer seguimiento en tiempo real y organizar mejor la operacion
                  del local, integrando tambien la impresion de comandas.
                </p>
              </div>

              <div class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6 text-white shadow-[0_24px_70px_rgba(2,6,23,0.32)]">
                <div class="mb-5 flex items-center justify-between gap-4">
                  <div>
                    <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Como funciona</p>
                    <h3 class="mt-2 text-2xl leading-tight font-bold tracking-[-0.04em]">
                      Flujo digital propuesto
                    </h3>
                  </div>
                  <span class="rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-1 text-xs font-bold text-cyan-300">
                    Uso interno
                  </span>
                </div>

                <div class="grid gap-4">
                  {
                    solutionSteps.map((step, index) => (
                      <div class="flex gap-4 rounded-3xl border border-white/10 bg-white/5 p-4">
                        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-emerald-500 text-sm font-bold text-slate-950">
                          0{index + 1}
                        </span>
                        <p class="m-0 text-[0.98rem] leading-7 text-slate-200">{step}</p>
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              {
                solutionBenefits.map((item) => (
                  <article class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6 shadow-[0_18px_60px_rgba(2,6,23,0.28)]">
                    <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl bg-emerald-500/12 text-sm font-bold text-emerald-400">
                      +
                    </div>
                    <h3 class="text-xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
                      {item.title}
                    </h3>
                    <p class="mt-3 text-[0.98rem] leading-7 text-slate-400">
                      {item.description}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section id="demo" class="px-0 py-20 text-white">
        <div class="mb-12 text-center">
          <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-sky-400">
            Comparacion de uso
          </p>
          <h2 class="text-4xl font-bold text-white md:text-5xl">
            Del proceso actual a una solucion más clara y accesible
          </h2>
          <p class="mx-auto mt-4 max-w-3xl text-slate-400">
            La propuesta reemplaza un proceso manual, menos estructurado y propenso a errores, por una interfaz clara, guiada y accesible para distintos niveles de experiencia tecnologica.
          </p>
        </div>

        <div class="mx-auto mb-20 grid max-w-6xl gap-10 px-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(340px,1.1fr)]">
          <div class="rounded-[28px] border border-white/10 bg-[#0B1120] p-6 opacity-90 shadow-2xl shadow-black/20">
            <div class="mb-4">
              <p class="mb-2 text-xs font-medium uppercase tracking-[0.2em] text-slate-500">
                Metodo actual
              </p>
              <h3 class="text-2xl font-semibold text-white">
                Registro poco estructurado
              </h3>
              <p class="mt-2 text-sm text-slate-400">
                Forma de trabajo mas manual, con menor claridad visual y mayor riesgo de errores.
              </p>
            </div>

            <div class="mb-4 grid gap-3 sm:grid-cols-2">
              <div class="rounded-2xl border border-white/5 bg-[#111827] p-4">
                <p class="text-sm font-medium text-white">Informacion dispersa</p>
                <p class="mt-1 text-sm text-slate-500">
                  Datos mezclados en anotaciones breves.
                </p>
              </div>

              <div class="rounded-2xl border border-white/5 bg-[#111827] p-4">
                <p class="text-sm font-medium text-white">Menor claridad</p>
                <p class="mt-1 text-sm text-slate-500">
                  Estado y observaciones poco visibles.
                </p>
              </div>
            </div>

            <div class="rounded-3xl border border-white/5 bg-[#020617] p-5">
              <div class="mb-4 flex items-center justify-between">
                <div>
                  <p class="text-xs uppercase tracking-wide text-slate-500">
                    Pedido actual
                  </p>
                  <p class="text-base font-semibold text-white">
                    Anotación manual del pedido
                  </p>
                </div>

                <span class="rounded-full bg-white/5 px-3 py-1 text-xs text-slate-400">
                  Sin guía visual
                </span>
              </div>

              <div class="space-y-3">
                <div class="rounded-2xl border border-white/5 bg-[#0B1120] p-4">
                  <p class="text-xs uppercase tracking-wide text-slate-500">Pedido</p>
                  <p class="mt-2 text-sm text-slate-300">
                    Hamb + bebida <br />
                    papas <br />
                    s/cebolla
                  </p>
                </div>

                <div class="rounded-2xl border border-white/5 bg-[#0B1120] p-4">
                  <p class="text-xs uppercase tracking-wide text-slate-500">Estado</p>
                  <p class="mt-2 text-sm font-medium text-amber-300">
                    Pendiente
                  </p>
                </div>

                <div class="rounded-2xl border border-white/5 bg-[#0B1120] p-4">
                  <p class="text-xs uppercase tracking-wide text-slate-500">Observaciones</p>
                  <p class="mt-2 text-sm text-slate-400">
                    Cliente espera. Posibles dudas en la lectura del pedido durante horas de alta demanda.
                  </p>
                </div>
              </div>

              <div class="mt-5 rounded-2xl border border-dashed border-white/10 bg-white/[0.02] px-4 py-3">
                <p class="text-sm text-slate-400">
                  No existe confirmacion inmediata ni una visualizacion clara del flujo del pedido.
                </p>
              </div>
            </div>

            <div class="mt-5 grid gap-3 sm:grid-cols-3">
              <div class="rounded-2xl border border-white/5 bg-[#111827] p-4">
                <p class="text-sm font-semibold text-white">Texto abreviado</p>
                <p class="mt-1 text-xs text-slate-500">
                  Puede dificultar la interpretacion.
                </p>
              </div>

              <div class="rounded-2xl border border-white/5 bg-[#111827] p-4">
                <p class="text-sm font-semibold text-white">Sin confirmacion</p>
                <p class="mt-1 text-xs text-slate-500">
                  El usuario no recibe feedback claro.
                </p>
              </div>

              <div class="rounded-2xl border border-white/5 bg-[#111827] p-4">
                <p class="text-sm font-semibold text-white">Más confusión</p>
                <p class="mt-1 text-xs text-slate-500">
                  Aumenta el riesgo de errores operativos.
                </p>
              </div>
            </div>
          </div>

          <div class="mx-auto w-full max-w-xl">
            <div class="rounded-[28px] border border-white/10 bg-[#0B1120] p-5 shadow-2xl shadow-black/30">
              <p class="mb-2 text-xs font-medium uppercase tracking-[0.2em] text-sky-400">
                Modo accesible activado
              </p>
                <div class="mb-4 flex items-center justify-between">
                  <div>
                    <p class="text-sm text-slate-400">Demo del sistema</p>
                  <h3 class="text-xl font-semibold text-white">Ingreso de pedido accesible</h3>
                </div>
                <span class="rounded-full bg-green-500/15 px-3 py-1 text-xs font-medium text-green-400">
                  Interfaz accesible
                </span>
              </div>

              <div class="mb-5 grid gap-3 sm:grid-cols-2">
                <div class="rounded-2xl border border-white/10 bg-[#111827] p-4">
                  <p class="text-sm font-medium text-white">Botones grandes</p>
                  <p class="mt-1 text-sm text-slate-400">Facilitan la seleccion sin errores.</p>
                </div>
                <div class="rounded-2xl border border-white/10 bg-[#111827] p-4">
                  <p class="text-sm font-medium text-white">Lectura clara</p>
                  <p class="mt-1 text-sm text-slate-400">Texto visible y jerarquia comprensible.</p>
                </div>
              </div>

              <div class="rounded-3xl border border-white/10 bg-[#020617] p-4">
                <div class="mb-4 flex items-center justify-between">
                  <div>
                    <p class="text-xs uppercase tracking-wide text-slate-500">Pedido actual</p>
                    <p class="text-base font-semibold text-white">Selecciona productos</p>
                  </div>
                  <span class="rounded-full bg-sky-500/15 px-3 py-1 text-xs text-sky-300">
                    Paso 1 de 2
                  </span>
                </div>

                <div class="space-y-3">
                  <button class="flex w-full items-center justify-between rounded-2xl border border-white/10 bg-[#1E293B] px-4 py-4 text-left transition hover:bg-[#273449]">
                    <span class="flex items-center gap-3">
                      <span class="text-2xl">🍔</span>
                      <span>
                        <span class="block text-base font-semibold text-white">Hamburguesa</span>
                        <span class="block text-sm text-slate-400">Seleccion rapida</span>
                      </span>
                    </span>
                    <span class="text-sm text-slate-300">Agregar</span>
                  </button>

                  <button class="flex w-full items-center justify-between rounded-2xl border border-white/10 bg-[#1E293B] px-4 py-4 text-left transition hover:bg-[#273449]">
                    <span class="flex items-center gap-3">
                      <span class="text-2xl">🥤</span>
                      <span>
                        <span class="block text-base font-semibold text-white">Bebida</span>
                        <span class="block text-sm text-slate-400">Opcion complementaria</span>
                      </span>
                    </span>
                    <span class="text-sm text-slate-300">Agregar</span>
                  </button>
                </div>

                <div class="mt-5 rounded-2xl border border-white/10 bg-[#0B1120] p-4">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-sm font-medium text-white">Resumen visible</p>
                      <p class="mt-1 text-sm text-slate-400">
                        Pedido claro, facil de revisar antes de confirmar.
                      </p>
                    </div>
                    <span class="rounded-full bg-green-500/15 px-3 py-1 text-xs font-medium text-green-400">
                      Sin errores
                    </span>
                  </div>

                  <div class="mt-4 space-y-2 text-sm text-slate-300">
                    <div class="flex justify-between">
                      <span>Hamburguesa</span>
                      <span>1</span>
                    </div>
                    <div class="flex justify-between">
                      <span>Bebida</span>
                      <span>1</span>
                    </div>
                  </div>

