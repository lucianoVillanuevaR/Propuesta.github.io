---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const sections = [
  { id: 'hero', label: 'Inicio' },
  { id: 'problema', label: 'Problema' },
  { id: 'solucion', label: 'Solucion' },
  { id: 'accesibilidad', label: 'Adopcion' },
  { id: 'funcionalidades', label: 'Funciones' },
  { id: 'impacto', label: 'Impacto' },
  { id: 'estado', label: 'Estado' },
];

const heroHighlights = [
  'Interfaz clara para usuarios con baja experiencia tecnologica',
  'Botones grandes, menos pasos y apoyo visual',
  'Registro y seguimiento digital de pedidos en tiempo real',
];

const heroStats = [
  { label: 'Enfoque principal', value: 'Accesibilidad real' },
  { label: 'Contexto', value: 'Pyme gastronomica' },
  { label: 'Operacion', value: 'Uso interno en local' },
];

const problemFlow = [
  'El pedido se recibe de forma presencial o desde plataformas de delivery.',
  'La informacion se anota manualmente en comandas o en un block de notas.',
  'La preparacion y entrega dependen de ese registro manual para continuar.',
];

const problemIssues = [
  {
    title: 'Errores de registro',
    description: 'La escritura manual aumenta el riesgo de errores, confusiones e interpretaciones incorrectas.',
  },
  {
    title: 'Perdida de informacion',
    description: 'Sin un sistema centralizado, los pedidos pueden perderse, duplicarse o quedar incompletos.',
  },
  {
    title: 'Desorganizacion operativa',
    description: 'En alta demanda se vuelve mas dificil mantener el orden de preparacion y entrega.',
  },
  {
    title: 'Sobrecarga al atender',
    description: 'Quien atiende debe dividir su atencion entre anotar, coordinar y entregar, reduciendo eficiencia.',
  },
];

const solutionSteps = [
  'Ingreso rapido de pedidos desde una interfaz web interna y clara.',
  'Registro automatico para mantener seguimiento en tiempo real.',
  'Organizacion del flujo de preparacion y entrega en un mismo sistema.',
  'Envio de comandas a impresion para mejorar la coordinacion con cocina.',
];

const solutionBenefits = [
  {
    title: 'Registro digital',
    description: 'Reemplaza la toma manual por una plataforma de uso interno orientada al trabajo diario del local.',
  },
  {
    title: 'Seguimiento en tiempo real',
    description: 'Cada pedido queda registrado automaticamente para mantener control claro de lo que esta en curso.',
  },
  {
    title: 'Operacion mas ordenada',
    description: 'Ayuda a mantener la secuencia de preparacion y entrega con menos confusion entre tareas.',
  },
  {
    title: 'Impresion de comandas',
    description: 'Integra el sistema con impresoras para enviar pedidos al area de cocina de forma automatica.',
  },
];

const accessibilityPoints = [
  'Botones grandes para reducir errores de seleccion.',
  'Menos pasos para completar un pedido.',
  'Lectura clara con jerarquia visual simple.',
  'Retroalimentacion inmediata para saber que accion se realizo.',
];

const accessibilityAudience = [
  {
    title: 'Adultos mayores',
    description: 'El proyecto prioriza una experiencia clara y comprensible para personas con menor familiaridad tecnologica.',
  },
  {
    title: 'Baja alfabetizacion digital',
    description: 'La solucion busca ser facil de adoptar dentro del negocio sin depender de capacitacion compleja.',
  },
  {
    title: 'Inclusividad de uso',
    description: 'Las decisiones de accesibilidad tambien favorecen a usuarios con necesidades visuales, motoras o cognitivas.',
  },
];

const features = [
  {
    title: 'Registro de pedidos',
    description: 'Ingreso rapido de pedidos presenciales desde una interfaz clara y de uso interno.',
  },
  {
    title: 'Pedidos en curso',
    description: 'Visualizacion del estado actual para mantener control del flujo de preparacion y entrega.',
  },
  {
    title: 'Impresion automatica',
    description: 'Envio de comandas al area de cocina mediante integracion con impresoras del local.',
  },
  {
    title: 'Historial de ventas',
    description: 'Consulta de pedidos anteriores para revisar actividad y apoyar la organizacion diaria.',
  },
  {
    title: 'Inventario basico',
    description: 'Control simple de productos e insumos asociados a la operacion del negocio.',
  },
  {
    title: 'Interfaz accesible',
    description: 'Navegacion sencilla, apoyo visual y menos pasos para facilitar la adopcion del sistema.',
  },
];

const impacts = [
  'Reduccion de errores en la toma de pedidos.',
  'Mejora en los tiempos de atencion y coordinacion interna.',
  'Mayor organizacion del negocio durante horas de alta demanda.',
  'Inclusion digital para usuarios con baja experiencia tecnologica.',
];

const statusItems = [
  {
    phase: 'Propuesta definida',
    description: 'El problema, los objetivos y el alcance del sistema ya fueron establecidos en el proyecto de titulo.',
  },
  {
    phase: 'Diseno en progreso',
    description: 'La interfaz se desarrolla con foco en simplicidad, accesibilidad y uso real dentro del local.',
  },
  {
    phase: 'Desarrollo proximo',
    description: 'La siguiente etapa considera implementar el sistema web, la logica de pedidos y el almacenamiento de datos.',
  },
  {
    phase: 'Evaluacion con usuarios',
    description: 'Se contemplan pruebas con usuarios reales, incluyendo adultos mayores, para validar facilidad de uso y adopcion.',
  },
];

const footerMeta = [
  'Luciano Villanueva Ramirez',
  'Ingenieria en Ejecucion en Computacion e Informatica',
  'Universidad del Bio-Bio',
];
---

<BaseLayout
  title="Sistema web de gestion de pedidos accesible"
  description="Landing page del proyecto de titulo sobre gestion de pedidos accesible para pymes del rubro gastronomico."
>
  <div class="relative overflow-hidden">
    <header class="sticky top-0 z-10 border-b border-white/8 bg-[#0f172acc] backdrop-blur-xl">
      <div class="relative z-[1] mx-auto flex w-[min(calc(100%-2rem),1180px)] flex-col items-start justify-between gap-5 py-4 lg:flex-row lg:items-center">
        <a
          class="inline-flex items-center gap-3.5 font-display text-base font-bold tracking-[-0.03em] text-slate-50"
          href="#hero"
          aria-label="Ir al inicio del proyecto"
        >
          <span>Sistema de pedidos accesible</span>
        </a>

        <nav class="flex flex-wrap justify-end gap-2" aria-label="Secciones principales">
          {
            sections.map((section) => (
              <a
                class="rounded-full px-4 py-3 text-[0.96rem] text-slate-400 transition hover:bg-white/8 hover:text-slate-50 focus-visible:bg-white/8 focus-visible:text-slate-50"
                href={`#${section.id}`}
              >
                {section.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main>
      <section class="px-0 pt-12 pb-18 sm:pt-16 sm:pb-18" id="hero">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="rounded-[32px] border border-white/8 bg-[#0b1120] p-6 shadow-soft md:p-8 lg:p-10">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)] lg:items-center">
              <div class="grid max-w-[42rem] gap-5">
                <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">
                  Proyecto de titulo 2026
                </span>

                <div class="grid gap-4">
                  <h1 class="m-0 max-w-[11ch] text-[clamp(3.3rem,8vw,6.1rem)] leading-[0.95] font-extrabold tracking-[-0.055em] text-slate-50">
                    Sistema de Gestion de Pedidos Accesible
                  </h1>
                  <p class="m-0 max-w-[40rem] text-[1.08rem] leading-7 text-slate-400 sm:text-[1.12rem] sm:leading-8">
                    Digitaliza la toma de pedidos con una interfaz clara, accesible y facil
                    de adoptar para usuarios con poca experiencia tecnologica.
                  </p>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row">
                  <a
                    class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3.5 text-sm font-bold text-slate-950 transition hover:bg-emerald-400"
                    href="#solucion"
                  >
                    Ver proyecto
                  </a>
                </div>

                <div class="grid gap-3 pt-2">
                  {
                    heroHighlights.map((item) => (
                      <div class="flex items-start gap-3 text-slate-300">
                        <span class="mt-1.5 h-2.5 w-2.5 rounded-full bg-cyan-400"></span>
                        <span class="text-[0.98rem] leading-7">{item}</span>
                      </div>
                    ))
                  }
                </div>
              </div>

              <div class="relative">
                <div class="absolute inset-x-8 top-6 h-24 rounded-full bg-cyan-400/12 blur-3xl"></div>
                <div class="relative overflow-hidden rounded-[30px] border border-white/8 bg-[#0f172a] p-5 text-white shadow-[0_28px_80px_rgba(2,6,23,0.45)]">
                  <div class="mb-5 flex items-center justify-between">
                    <div>
                      <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Sistema interno</p>
                      <h3 class="mt-2 text-2xl leading-tight font-bold tracking-[-0.04em]">
                        Flujo de pedidos accesible
                      </h3>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-white/5 px-3 py-2 text-right">
                      <p class="text-[0.68rem] uppercase tracking-[0.24em] text-slate-400">Estado</p>
                      <p class="mt-1 text-sm font-semibold text-emerald-400">Propuesta definida</p>
                    </div>
                  </div>

                  <div class="grid gap-3">
                    <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
                      <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Pedido activo</p>
                      <p class="mt-2 text-lg font-semibold">Hamburguesa + bebida + papas</p>
                      <p class="mt-1 text-sm text-slate-300">Ingreso rapido, lectura simple y pasos reducidos.</p>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-3">
                      {
                        heroStats.map((stat) => (
                          <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
                            <p class="text-xs uppercase tracking-[0.2em] text-slate-400">{stat.label}</p>
                            <p class="mt-3 text-sm leading-6 font-semibold text-white">{stat.value}</p>
                          </div>
                        ))
                      }
                    </div>

                    <div class="rounded-3xl border border-cyan-400/20 bg-cyan-400/10 p-4">
                      <p class="text-xs uppercase tracking-[0.24em] text-cyan-300">Objetivo</p>
                      <p class="mt-2 text-sm leading-7 text-slate-200">
                        Reducir errores, ordenar la operacion diaria y mejorar la adopcion
                        tecnologica dentro del negocio.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="problema">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(320px,1.08fr)] lg:items-start">
            <div class="grid gap-5">
              <div class="grid max-w-[42rem] gap-3.5">
                <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Problema</span>
                <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-50">
                  Cuando todo depende del papel, el ritmo se rompe.
                </h2>
                <p class="m-0 max-w-[38rem] text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                  Segun la propuesta, la gestion actual de pedidos se realiza de manera manual.
                  Esto sostiene la operacion diaria, pero genera errores, perdida de informacion
                  y desorden, especialmente en momentos de alta demanda.
                </p>
                <p class="m-0 max-w-[38rem] text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                  Ademas del desorden operativo, la empresa necesita una solucion que pueda
                  ser utilizada por personas con distintos niveles de manejo tecnologico,
                  especialmente adultos mayores o usuarios con baja alfabetizacion digital.
                </p>
              </div>

              <div class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6">
                <div class="mb-4 flex items-center justify-between gap-4">
                  <div>
                    <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Proceso actual</p>
                    <h3 class="mt-2 text-2xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
                      Flujo manual de atencion
                    </h3>
                  </div>
                  <span class="rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1 text-xs font-bold text-amber-300">
                    Alto riesgo en horas punta
                  </span>
                </div>

                <div class="grid gap-4">
                  {
                    problemFlow.map((step, index) => (
                      <div class="flex gap-4 rounded-3xl border border-white/8 bg-white/4 p-4">
                        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-slate-50 text-sm font-bold text-slate-950">
                          0{index + 1}
                        </span>
                        <p class="m-0 text-[0.98rem] leading-7 text-slate-300">{step}</p>
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              {
                problemIssues.map((item) => (
                  <article class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6 shadow-[0_18px_60px_rgba(2,6,23,0.28)]">
                    <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl bg-cyan-400/10 text-sm font-bold text-cyan-300">
                      !
                    </div>
                    <h3 class="text-xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
                      {item.title}
                    </h3>
                    <p class="mt-3 text-[0.98rem] leading-7 text-slate-400">
                      {item.description}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="solucion">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,0.98fr)_minmax(320px,1.02fr)] lg:items-start">
            <div class="grid gap-5">
              <div class="grid max-w-[44rem] gap-3.5">
                <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Solucion</span>
                <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-50">
                  Un sistema interno para ordenar cada pedido desde el primer clic.
                </h2>
                <p class="m-0 max-w-[40rem] text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                  La propuesta plantea un sistema web de uso interno para registrar pedidos
                  presenciales, hacer seguimiento en tiempo real y organizar mejor la operacion
                  del local, integrando tambien la impresion de comandas.
                </p>
              </div>

              <div class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6 text-white shadow-[0_24px_70px_rgba(2,6,23,0.32)]">
                <div class="mb-5 flex items-center justify-between gap-4">
                  <div>
                    <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Como funciona</p>
                    <h3 class="mt-2 text-2xl leading-tight font-bold tracking-[-0.04em]">
                      Flujo digital propuesto
                    </h3>
                  </div>
                  <span class="rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-1 text-xs font-bold text-cyan-300">
                    Uso interno
                  </span>
                </div>

                <div class="grid gap-4">
                  {
                    solutionSteps.map((step, index) => (
                      <div class="flex gap-4 rounded-3xl border border-white/10 bg-white/5 p-4">
                        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-emerald-500 text-sm font-bold text-slate-950">
                          0{index + 1}
                        </span>
                        <p class="m-0 text-[0.98rem] leading-7 text-slate-200">{step}</p>
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              {
                solutionBenefits.map((item) => (
                  <article class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6 shadow-[0_18px_60px_rgba(2,6,23,0.28)]">
                    <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl bg-emerald-500/12 text-sm font-bold text-emerald-400">
                      +
                    </div>
                    <h3 class="text-xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
                      {item.title}
                    </h3>
                    <p class="mt-3 text-[0.98rem] leading-7 text-slate-400">
                      {item.description}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="accesibilidad">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="rounded-[32px] border border-white/8 bg-[#0b1120] p-6 shadow-soft md:p-8 lg:p-10">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(320px,0.95fr)] lg:items-start">
              <div class="grid gap-5">
                <div class="grid max-w-[44rem] gap-3.5">
                  <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Tecnologia facil de adoptar</span>
                  <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-50">
                    Disenado para personas reales en el trabajo diario.
                  </h2>
                  <p class="m-0 max-w-[41rem] text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                    El punto diferencial del proyecto es su enfoque en accesibilidad y usabilidad.
                    Segun el PDF, el sistema se disena para adultos mayores y usuarios con baja
                    alfabetizacion digital, priorizando una experiencia simple, clara y facil de adoptar.
                  </p>
                </div>

                <div class="grid gap-3">
                  {
                    accessibilityPoints.map((item) => (
                      <div class="flex items-start gap-4 rounded-3xl border border-white/8 bg-white/4 p-4">
                        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-emerald-500/12 text-sm font-bold text-emerald-400">
                          OK
                        </span>
                        <p class="m-0 text-[0.98rem] leading-7 text-slate-300">{item}</p>
                      </div>
                    ))
                  }
                </div>

                <div class="rounded-[28px] border border-white/8 bg-[#0f172a] p-6">
                  <p class="text-xs uppercase tracking-[0.24em] text-cyan-300">En la practica</p>
                  <div class="mt-4 grid gap-3">
                    <p class="text-[0.98rem] leading-7 text-slate-300">Interfaz comprensible para personas con poca familiaridad tecnologica.</p>
                    <p class="text-[0.98rem] leading-7 text-slate-300">Menos friccion al registrar pedidos durante la operacion diaria.</p>
                  </div>
                </div>
              </div>

              <div class="grid gap-4">
                {
                  accessibilityAudience.map((item) => (
                    <article class="rounded-[28px] border border-white/8 bg-[#0f172a] p-6 shadow-[0_18px_60px_rgba(2,6,23,0.28)]">
                      <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Accesibilidad</p>
                      <h3 class="mt-3 text-xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
                        {item.title}
                      </h3>
                      <p class="mt-3 text-[0.98rem] leading-7 text-slate-400">
                        {item.description}
                      </p>
                    </article>
                  ))
                }

                <div class="rounded-[28px] border border-cyan-400/20 bg-cyan-400/10 p-6">
                  <p class="text-xs uppercase tracking-[0.24em] text-cyan-300">Base conceptual</p>
                  <p class="mt-3 text-[0.98rem] leading-7 text-slate-200">
                    La propuesta toma como referencia principios de accesibilidad orientados a
                    interacciones comprensibles, simples y adaptadas al contexto real del negocio.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="funcionalidades">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="mb-8 grid max-w-[46rem] gap-3.5">
            <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Funcionalidades</span>
            <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-50">
              Funciones clave para ordenar la operacion diaria.
            </h2>
            <p class="m-0 text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
              Estas funcionalidades fueron definidas en la propuesta como base del sistema:
              registro, seguimiento, impresion, historial e inventario basico.
            </p>
          </div>

          <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {
              features.map((feature) => (
                <article class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6 shadow-[0_18px_60px_rgba(2,6,23,0.26)]">
                  <div class="mb-4 h-2.5 w-14 rounded-full bg-linear-to-r from-emerald-400 to-cyan-400"></div>
                  <h3 class="mb-3 text-xl leading-tight font-bold tracking-[-0.045em] text-slate-50">
                    {feature.title}
                  </h3>
                  <p class="max-w-[34rem] text-[1.02rem] leading-7 text-slate-400">
                    {feature.description}
                  </p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="impacto">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(320px,1.08fr)] lg:items-start">
            <div class="grid max-w-[42rem] gap-3.5">
              <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Impacto</span>
              <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-50">
                Menos errores, mejor ritmo y una adopcion mas inclusiva.
              </h2>
              <p class="m-0 text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                De acuerdo con la propuesta, el sistema busca mejorar la eficiencia operativa,
                reducir fallas del registro manual y facilitar el uso de tecnologia dentro de
                una pyme gastronomica.
              </p>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              {
                impacts.map((item, index) => (
                  <article class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6">
                    <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl bg-cyan-400/10 text-sm font-bold text-cyan-300">
                      0{index + 1}
                    </div>
                    <p class="text-[1rem] leading-7 text-slate-300">{item}</p>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="estado">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="rounded-[32px] border border-white/8 bg-[#0b1120] p-6 shadow-soft md:p-8 lg:p-10">
            <div class="mb-8 grid max-w-[45rem] gap-3.5">
              <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Estado del proyecto</span>
              <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-50">
                El proyecto ya tiene direccion clara y siguientes pasos definidos.
              </h2>
              <p class="m-0 text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                El documento ya establece el problema, la solucion propuesta y la estrategia
                de evaluacion. Sobre esa base, el proyecto avanza desde el diseno hacia la
                implementacion y validacion con usuarios reales.
              </p>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              {
                statusItems.map((item) => (
                  <article class="rounded-[28px] border border-white/8 bg-[#0f172a] p-6">
                    <p class="text-xs uppercase tracking-[0.24em] text-cyan-300">{item.phase}</p>
                    <p class="mt-4 text-[1rem] leading-7 text-slate-300">{item.description}</p>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="px-0 pt-8 pb-16">
      <div class="relative z-[1] mx-auto grid w-[min(calc(100%-2rem),1180px)] gap-6 border-t border-white/8 pt-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
        <div class="grid gap-3">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-300">
            Proyecto de titulo
          </p>
          <h2 class="max-w-[14ch] text-3xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
            Sistema de Gestion de Pedidos Accesible
          </h2>
          <p class="max-w-[40rem] text-[1rem] leading-7 text-slate-400">
            Landing informativa del proyecto enfocado en digitalizar la gestion de pedidos
            para pymes gastronomicas con accesibilidad como eje principal.
          </p>
        </div>

        <div class="grid gap-2 text-[0.95rem] text-slate-400 lg:text-right">
          {
            footerMeta.map((item) => (
              <span>{item}</span>
            ))
          }
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>
