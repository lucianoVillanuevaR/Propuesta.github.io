---
import DemoPreview from '../components/DemoPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const sections = [
  { id: 'inicio', label: 'Inicio' },
  { id: 'problema', label: 'Problema' },
  { id: 'solucion', label: 'Solución' },
  { id: 'demo-preview', label: 'Demo' },
  { id: 'funciones', label: 'Funciones' },
  { id: 'accesibilidad', label: 'Accesibilidad' },
  { id: 'impacto', label: 'Impacto' },
  { id: 'fundamento', label: 'Fundamento' },
  { id: 'estado', label: 'Estado' },
];

const problemFlow = [
  'El pedido se recibe de forma presencial o desde plataformas de delivery.',
  'La información se anota manualmente en comandas o en un block de notas.',
  'La preparación y entrega dependen de ese registro manual para continuar.',
];

const problemIssues = [
  {
    title: 'Errores de registro',
    description: 'La escritura manual aumenta el riesgo de errores, confusiones e interpretaciones incorrectas.',
  },
  {
    title: 'Pérdida de información',
    description: 'Sin un sistema centralizado, los pedidos pueden perderse, duplicarse o quedar incompletos.',
  },
  {
    title: 'Desorganización operativa',
    description: 'En alta demanda se vuelve más difícil mantener el orden de preparación y entrega.',
  },
  {
    title: 'Sobrecarga al atender',
    description: 'Quien atiende debe dividir su atención entre anotar, coordinar y entregar, reduciendo eficiencia.',
  },
];

const solutionSteps = [
  'Seleccionar productos en una interfaz guiada.',
  'Confirmar el pedido con resumen claro.',
  'Generar ticket para cocina.',
  'Registrar automáticamente en el sistema.',
];

const solutionBenefits = [
  {
    title: 'Registro digital',
    description: 'Reemplaza la toma manual por una plataforma de uso interno orientada al trabajo diario del local.',
  },
  {
    title: 'Seguimiento en tiempo real',
    description: 'Cada pedido queda registrado automáticamente para mantener control claro de lo que está en curso.',
  },
  {
    title: 'Operación más ordenada',
    description: 'Ayuda a mantener la secuencia de preparación y entrega con menos confusión entre tareas.',
  },
  {
    title: 'Impresión de comandas',
    description: 'Integra el sistema con impresoras para enviar pedidos al área de cocina de forma automática.',
  },
];

const statusItems = [
  {
    phase: 'Propuesta definida',
    description: 'El problema, los objetivos y el alcance del sistema ya fueron establecidos en el proyecto de título.',
  },
  {
    phase: 'Diseño en progreso',
    description: 'La interfaz se desarrolla con foco en simplicidad, accesibilidad y uso real dentro del local.',
  },
  {
    phase: 'Desarrollo proximo',
    description: 'La siguiente etapa considera implementar el sistema web, la lógica de pedidos y el almacenamiento de datos.',
  },
  {
    phase: 'Evaluación con usuarios',
    description: 'Se contemplan pruebas con usuarios reales, incluyendo adultos mayores, para validar facilidad de uso y adopción.',
  },
];

const accessibilityPrinciples = [
  {
    title: 'Alto contraste',
    description: 'Combinaciones visuales de lectura clara para mejorar identificación de acciones y estados.',
    tag: 'WCAG 1.4.3',
  },
  {
    title: 'Botones grandes',
    description: 'Objetivos táctiles amplios para reducir errores de selección en entornos con alta carga operativa.',
    tag: 'WCAG 2.5.5',
  },
  {
    title: 'Flujo guiado paso a paso',
    description: 'Secuencia explícita de tareas para disminuir confusión y mejorar autonomía de uso.',
    tag: 'WCAG 3.3.2',
  },
  {
    title: 'Reducción de carga cognitiva',
    description: 'Lenguaje simple, jerarquía visual y retroalimentación inmediata en cada acción crítica.',
    tag: 'WCAG 3.1 + 3.3',
  },
];

const impactMetrics = [
  {
    value: '-35%',
    label: 'Reducción estimada de errores de pedido',
    detail: 'Meta de evaluación piloto comparando registro manual vs digital.',
  },
  {
    value: '-25%',
    label: 'Disminución del tiempo promedio de atención',
    detail: 'Medición desde toma de pedido hasta envío a cocina.',
  },
  {
    value: '100%',
    label: 'Trazabilidad de pedidos registrados',
    detail: 'Cada pedido queda guardado con estado y confirmación.',
  },
];

const foundationCards = [
  {
    title: 'Optimización del proceso',
    subtitle: 'Objetivo',
    description:
      'Digitalizar la gestión de pedidos para reducir errores, mejorar los tiempos de atención y facilitar el trabajo diario mediante una interfaz accesible.',
  },
  {
    title: 'Desarrollo iterativo',
    subtitle: 'Metodología',
    description:
      'El sistema se desarrolla utilizando metodología ágil (Scrum), permitiendo iteraciones cortas, validación continua y adaptación según el usuario.',
  },
  {
    title: 'Estructura del sistema',
    subtitle: 'Arquitectura',
    description:
      'Aplicación web compuesta por interfaz accesible (frontend), lógica de gestión (backend) y base de datos centralizada.',
  },
  {
    title: 'Pruebas con usuarios reales',
    subtitle: 'Validación',
    description:
      'El sistema es evaluado con usuarios del entorno real, incluyendo adultos mayores, para medir facilidad de uso y efectividad.',
  },
];

const existingSystemsLimitations = [
  {
    title: 'Alto costo',
    description: 'Soluciones como POS comerciales requieren pagos mensuales.',
  },
  {
    title: 'Complejidad',
    description: 'Interfaces diseñadas para usuarios técnicos.',
  },
  {
    title: 'Poca accesibilidad',
    description: 'No consideran usuarios con baja alfabetizacion digital.',
  },
];

const footerMeta = [
  'Luciano Villanueva Ramirez',
  'Ingeniería en Ejecución en Computación e Informática',
  'Universidad del Bio-Bio',
];
---

<BaseLayout
  title="Sistema de gestión de pedidos accesible que reduce errores operativos en pymes gastronómicas"
  description="Landing page del proyecto de título sobre gestión de pedidos accesible para pymes del rubro gastronómico."
>
  <div class="relative overflow-hidden">
    <header class="sticky top-0 z-10 border-b border-white/8 bg-[#0f172acc] backdrop-blur-xl">
      <div class="relative z-[1] mx-auto flex w-[min(calc(100%-2rem),1180px)] flex-col items-start justify-between gap-5 py-4 lg:flex-row lg:items-center">
        <a
          class="inline-flex items-center gap-3.5 font-display text-base font-bold tracking-[-0.03em] text-slate-50"
          href="#inicio"
          aria-label="Ir al inicio del proyecto"
        >
          <span>Sistema de pedidos accesible</span>
        </a>

        <nav class="flex flex-wrap justify-end gap-2" aria-label="Secciones principales">
          {
            sections.map((section) => (
              <a
                class="rounded-full px-4 py-3 text-[0.96rem] text-slate-400 transition hover:bg-white/8 hover:text-slate-50 focus-visible:bg-white/8 focus-visible:text-slate-50"
                href={section.href ?? `#${section.id}`}
              >
                {section.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main>
      <section id="inicio" class="relative overflow-hidden text-white">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(56,189,248,0.08),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(34,197,94,0.06),transparent_30%)]"></div>

        <div class="relative mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-28">
          <div class="max-w-4xl">
            <p class="mb-4 inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-1 text-sm text-sky-300">
              Proyecto de título - Sistema web accesible
            </p>

            <p class="mb-4 text-sm font-medium text-sky-400 md:text-base">
              Diseñado para personas reales, no expertos en tecnología
            </p>

            <h1 class="max-w-5xl text-4xl font-bold leading-tight md:text-6xl">
              Sistema de gestión de pedidos <span class="text-sky-400">accesible</span> para pymes gastronómicas
            </h1>

            <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
              Interfaz clara y fácil de usar, diseñada para adultos mayores y usuarios con baja experiencia digital.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
              <a
                href="#demo-preview"
                class="rounded-full bg-green-500 px-6 py-3 font-semibold text-slate-950 transition hover:bg-green-400"
              >
                Ver accesibilidad aplicada
              </a>
            </div>

            <div class="mt-5 text-sm text-slate-400">
              + Fácil de aprender en minutos · + Reduce errores · + Mejora la organización del local
            </div>

            <div class="mt-10 grid gap-4 md:grid-cols-3">
              <div class="rounded-2xl border border-white/10 bg-[#0B1120] p-5 transition hover:border-sky-400/30">
                <p class="text-sm font-semibold text-white">Interfaz simple y guiada</p>
                <p class="mt-2 text-sm text-slate-400">
                  Menos pasos y menos decisiones por acción.
                </p>
              </div>

              <div class="rounded-2xl border border-white/10 bg-[#0B1120] p-5 transition hover:border-sky-400/30">
                <p class="text-sm font-semibold text-white">Pensado para usuarios con poca experiencia digital</p>
                <p class="mt-2 text-sm text-slate-400">
                  Uso fácil para adultos mayores y nuevos usuarios.
                </p>
              </div>

              <div class="rounded-2xl border border-white/10 bg-[#0B1120] p-5 transition hover:border-sky-400/30">
                <p class="text-sm font-semibold text-white">Estado claro en todo momento</p>
                <p class="mt-2 text-sm text-slate-400">
                  El usuario siempre sabe qué está pasando.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="problema">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(320px,1.08fr)] lg:items-start">
            <div class="grid gap-5">
              <div class="grid max-w-[42rem] gap-3.5">
                <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Problema</span>
                <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-50">
                  Cuando todo depende del papel, el ritmo se rompe.
                </h2>
                <p class="m-0 max-w-[38rem] text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                  Según la propuesta, la gestión actual de pedidos se realiza de manera manual.
                  Esto sostiene la operación diaria, pero genera errores, pérdida de información
                  y desorden, especialmente en momentos de alta demanda.
                </p>
                <p class="m-0 max-w-[38rem] text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                  Además del desorden operativo, la empresa necesita una solución que pueda
                  ser utilizada por personas con distintos niveles de manejo tecnológico,
                  especialmente adultos mayores o usuarios con baja alfabetización digital.
                </p>
              </div>

              <div class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6">
                <div class="mb-4 flex items-center justify-between gap-4">
                  <div>
                    <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Proceso actual</p>
                    <h3 class="mt-2 text-2xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
                      Flujo manual de atención
                    </h3>
                  </div>
                  <span class="rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1 text-xs font-bold text-amber-300">
                    Alto riesgo en horas punta
                  </span>
                </div>

                <div class="grid gap-4">
                  {
                    problemFlow.map((step, index) => (
                      <div class="flex gap-4 rounded-3xl border border-white/8 bg-white/4 p-4">
                        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-slate-50 text-sm font-bold text-slate-950">
                          0{index + 1}
                        </span>
                        <p class="m-0 text-[0.98rem] leading-7 text-slate-300">{step}</p>
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              {
                problemIssues.map((item) => (
                  <article class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6 shadow-[0_18px_60px_rgba(2,6,23,0.28)]">
                    <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl bg-cyan-400/10 text-sm font-bold text-cyan-300">
                      !
                    </div>
                    <h3 class="text-xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
                      {item.title}
                    </h3>
                    <p class="mt-3 text-[0.98rem] leading-7 text-slate-400">
                      {item.description}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="solucion">
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,0.98fr)_minmax(320px,1.02fr)] lg:items-start">
            <div class="grid gap-5">
              <div class="grid max-w-[44rem] gap-3.5">
                <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Solución</span>
                <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-50">
                  Un sistema interno para ordenar cada pedido desde el primer clic.
                </h2>
                <p class="m-0 max-w-[40rem] text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                  La propuesta plantea un sistema web de uso interno para registrar pedidos
                  presenciales, hacer seguimiento en tiempo real y organizar mejor la operación
                  del local, integrando también la impresión de comandas.
                </p>
              </div>

              <div class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6 text-white shadow-[0_24px_70px_rgba(2,6,23,0.32)]">
                <div class="mb-5 flex items-center justify-between gap-4">
                  <div>
                    <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Cómo funciona</p>
                    <h3 class="mt-2 text-2xl leading-tight font-bold tracking-[-0.04em]">
                      Flujo digital propuesto
                    </h3>
                  </div>
                  <span class="rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-1 text-xs font-bold text-cyan-300">
                    Uso interno
                  </span>
                </div>

                <div class="grid gap-4">
                  {
                    solutionSteps.map((step, index) => (
                      <div class="flex gap-4 rounded-3xl border border-white/10 bg-white/5 p-4">
                        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-emerald-500 text-sm font-bold text-slate-950">
                          0{index + 1}
                        </span>
                        <p class="m-0 text-[0.98rem] leading-7 text-slate-200">{step}</p>
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              {
                solutionBenefits.map((item) => (
                  <article class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6 shadow-[0_18px_60px_rgba(2,6,23,0.28)]">
                    <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl bg-emerald-500/12 text-sm font-bold text-emerald-400">
                      +
                    </div>
                    <h3 class="text-xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
                      {item.title}
                    </h3>
                    <p class="mt-3 text-[0.98rem] leading-7 text-slate-400">
                      {item.description}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <DemoPreview />

      <section id="funciones" class="py-20 text-white">
        <div class="mx-auto max-w-6xl px-6">
          <div class="mb-14 text-center">
            <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-sky-400">
              Funcionalidades
            </p>
            <h2 class="text-3xl font-bold md:text-4xl">
              Funciones diseñadas para simplificar la operación
            </h2>
            <p class="mx-auto mt-4 max-w-3xl text-slate-400">
              El sistema propone un conjunto de funcionalidades orientadas a mejorar el registro,
              seguimiento y organización de pedidos en contextos reales de trabajo.
            </p>
          </div>

          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            <div class="rounded-3xl border border-white/10 bg-[#0B1120] p-6">
              <h3 class="mb-2 text-lg font-semibold">Registro de pedidos</h3>
              <p class="text-sm text-slate-400">
                Ingreso rapido y estructurado de pedidos, reduciendo errores del registro manual.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-[#0B1120] p-6">
              <h3 class="mb-2 text-lg font-semibold">Seguimiento en tiempo real</h3>
              <p class="text-sm text-slate-400">
                Visualización clara del estado del pedido durante todo el proceso de atención.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-[#0B1120] p-6">
              <h3 class="mb-2 text-lg font-semibold">Impresión automática</h3>
              <p class="text-sm text-slate-400">
                Envío automático de pedidos a cocina mediante impresión, reduciendo tiempos de comunicación.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-[#0B1120] p-6">
              <h3 class="mb-2 text-lg font-semibold">Historial de pedidos</h3>
              <p class="text-sm text-slate-400">
                Registro organizado de ventas realizadas para facilitar el control y consulta posterior.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-[#0B1120] p-6">
              <h3 class="mb-2 text-lg font-semibold">Control basico de inventario</h3>
              <p class="text-sm text-slate-400">
                Apoyo en la gestión de productos disponibles dentro de la operación diaria del negocio.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-[#0B1120] p-6">
              <h3 class="mb-2 text-lg font-semibold">Interfaz accesible</h3>
              <p class="text-sm text-slate-400">
                Diseño claro y fácil de usar para distintos niveles de experiencia digital.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="accesibilidad" class="py-20 text-white">
        <div class="mx-auto max-w-6xl px-6">
          <div class="mb-12 text-center">
            <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-sky-400">
              Accesibilidad aplicada
            </p>
            <h2 class="text-3xl font-bold md:text-4xl">
              Principios técnicos de accesibilidad considerados en el sistema
            </h2>
            <p class="mx-auto mt-4 max-w-3xl text-slate-400">
              La propuesta incorpora criterios basados en WCAG 2.1 para fortalecer legibilidad, usabilidad y autonomía,
              especialmente en usuarios mayores o con baja experiencia digital.
            </p>
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            {
              accessibilityPrinciples.map((item) => (
                <article class="rounded-3xl border border-white/10 bg-[#0B1120] p-6">
                  <div class="mb-3 flex items-center justify-between gap-3">
                    <h3 class="text-lg font-semibold text-white">{item.title}</h3>
                    <span class="rounded-full border border-cyan-400/25 bg-cyan-400/10 px-3 py-1 text-xs font-semibold text-cyan-300">
                      {item.tag}
                    </span>
                  </div>
                  <p class="text-sm leading-7 text-slate-400">{item.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="impacto" class="py-20 text-white">
        <div class="mx-auto max-w-6xl px-6">
          <div class="mb-14 text-center">
            <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-sky-400">
              Impacto esperado
            </p>
            <h2 class="text-3xl font-bold md:text-4xl">
              Beneficios en la operacion diaria del negocio
            </h2>
            <p class="mx-auto mt-4 max-w-3xl text-slate-400">
              La implementación del sistema busca mejorar la eficiencia operativa,
              reducir errores y facilitar el uso de tecnología en entornos reales de trabajo.
            </p>
          </div>

          <div class="mb-8 grid gap-6 md:grid-cols-3">
            {
              impactMetrics.map((item) => (
                <article class="rounded-3xl border border-cyan-400/20 bg-[#071125] p-6">
                  <p class="text-3xl font-extrabold tracking-[-0.04em] text-cyan-300">{item.value}</p>
                  <p class="mt-2 text-sm font-semibold text-white">{item.label}</p>
                  <p class="mt-2 text-sm text-slate-400">{item.detail}</p>
                </article>
              ))
            }
          </div>

          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-3xl border border-white/10 bg-[#0B1120] p-6">
              <h3 class="mb-2 flex min-h-[3.25rem] items-start gap-2 text-lg font-semibold text-green-400">
                <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-green-500/15 text-sm leading-none text-green-300">↓</span>
                Menos errores
              </h3>
              <p class="text-sm text-slate-400">
                Disminucion de errores en la toma y registro de pedidos.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-[#0B1120] p-6">
              <h3 class="mb-2 flex min-h-[3.25rem] items-start gap-2 text-lg font-semibold text-green-400">
                <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-cyan-500/15 text-sm leading-none text-cyan-300">↑</span>
                Mayor organización
              </h3>
              <p class="text-sm text-slate-400">
                Mejora en la gestión del flujo de pedidos dentro del local.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-[#0B1120] p-6">
              <h3 class="mb-2 flex min-h-[3.25rem] items-start gap-2 text-lg font-semibold text-green-400">
