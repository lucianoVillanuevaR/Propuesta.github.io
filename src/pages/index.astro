  <script>
    (() => {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const backToTopBtn = document.getElementById('back-to-top');

      if (backToTopBtn instanceof HTMLButtonElement) {
        const toggleBackToTop = () => {
          const shouldShow = window.scrollY > 420;
          backToTopBtn.classList.toggle('opacity-0', !shouldShow);
          backToTopBtn.classList.toggle('translate-y-4', !shouldShow);
          backToTopBtn.classList.toggle('pointer-events-none', !shouldShow);
          backToTopBtn.classList.toggle('opacity-100', shouldShow);
          backToTopBtn.classList.toggle('translate-y-0', shouldShow);
          backToTopBtn.classList.toggle('pointer-events-auto', shouldShow);
        };

        backToTopBtn.addEventListener('click', () => {
          window.scrollTo({
            top: 0,
            behavior: reduceMotion ? 'auto' : 'smooth',
          });
        });

        window.addEventListener('scroll', toggleBackToTop, { passive: true });
        toggleBackToTop();
      }

      if (reduceMotion) return;

      const targets = Array.from(
        document.querySelectorAll(
          [
            'main > section > div',
            'main section article',
            'footer > div > div',
          ].join(', ')
        )
      ).filter((el) => {
        if (!(el instanceof HTMLElement)) return false;
        const rect = el.getBoundingClientRect();
        return rect.width > 120 && rect.height > 56;
      });

      const deduped = Array.from(new Set(targets));

      deduped.forEach((el, index) => {
        el.classList.add('reveal-up');
        el.style.setProperty('--reveal-delay', `${(index % 5) * 36}ms`);
      });

      const liftTargets = Array.from(
        document.querySelectorAll(
          [
            'main section article',
            'main section [class*="rounded-2xl"]',
            'main section [class*="rounded-3xl"]',
            'main section [class*="rounded-[28px]"]',
            'main section [class*="rounded-[32px]"]',
          ].join(', ')
        )
      );

      liftTargets.forEach((el) => {
        if (el instanceof HTMLElement) el.classList.add('interactive-lift');
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '0px 0px -8% 0px', threshold: 0.12 }
      );

      deduped.forEach((el) => {
        if (!(el instanceof HTMLElement)) return;
        const top = el.getBoundingClientRect().top;
        if (top <= window.innerHeight * 0.9) {
          el.classList.add('is-visible');
          return;
        }
        observer.observe(el);
      });
    })();
  </script>
