---
import DemoPreview from '../components/DemoPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollToTopButton from '../components/ScrollToTopButton.astro';
import '../styles/global.css';

const sections = [
  { id: 'inicio', label: 'Inicio' },
  { id: 'contexto-negocio', label: 'Contexto' },
  { id: 'problema', label: 'Problema' },
  { id: 'propuesta', label: 'Propuesta' },
  { id: 'relacion-problema', label: 'Relación' },
  { id: 'flujo-sistema', label: 'Flujo' },
  { id: 'demo-preview', label: 'Demo', href: '/Propuesta.github.io/demo/' },
  { id: 'accesibilidad', label: 'Accesibilidad' },
  { id: 'viabilidad', label: 'Viabilidad' },
  { id: 'validacion', label: 'Validación' },
  { id: 'cierre', label: 'Cierre' },
];

const problemFlow = [
  'El pedido se recibe de forma presencial o desde plataformas de delivery.',
  'La información se anota manualmente en comandas o en un block de notas.',
  'La preparación y entrega dependen de ese registro manual para continuar.',
];

const problemIssues = [
  {
    title: 'Registro manual poco claro',
    description: 'La escritura manual aumenta el riesgo de errores, confusiones e interpretaciones incorrectas.',
  },
  {
    title: 'Información dispersa',
    description: 'Sin un sistema centralizado, los pedidos pueden perderse, duplicarse o quedar incompletos.',
  },
  {
    title: 'Falta de seguimiento',
    description: 'En alta demanda se vuelve más difícil mantener el orden de preparación y entrega.',
  },
  {
    title: 'Sobrecarga al atender',
    description: 'Quien atiende debe dividir su atención entre anotar, coordinar y entregar, reduciendo eficiencia.',
  },
];

const proposalSteps = [
  'Ingreso rápido de pedidos desde una interfaz web interna y clara.',
  'Registro automático para mantener seguimiento en tiempo real.',
  'Organización del flujo de preparación y entrega en un mismo sistema.',
  'Envío de comandas a impresión para mejorar la coordinación con cocina.',
];

const proposalAxes = [
  {
    title: 'Digitalización del registro',
    description: 'El sistema reemplaza el método manual por un registro centralizado y comprensible dentro del local.',
  },
  {
    title: 'Seguimiento del pedido',
    description: 'Cada pedido queda visible durante su proceso de preparación y entrega, favoreciendo el orden operativo.',
  },
  {
    title: 'Apoyo a la coordinación interna',
    description: 'La información se mantiene disponible para atención y cocina, reduciendo confusiones entre tareas.',
  },
  {
    title: 'Impresión de comandas',
    description: 'Se contempla integración con impresoras para facilitar el traspaso del pedido al área de preparación.',
  },
];

const accessibilityPrinciples = [
  {
    title: 'Botones grandes y fácilmente identificables',
    description: 'Uso de botones grandes y fácilmente identificables.',
  },
  {
    title: 'Reducción de pasos',
    description: 'Reducción de pasos en el flujo de interacción.',
  },
  {
    title: 'Mensajes claros',
    description: 'Mensajes claros y confirmaciones visibles.',
  },
  {
    title: 'Alto contraste',
    description: 'Alto contraste para mejorar la legibilidad.',
  },
];

const comparisonRows = [
  { current: 'Registro manual', proposed: 'Registro digital guiado' },
  { current: 'Errores frecuentes', proposed: 'Control visible del pedido' },
  { current: 'Información dispersa', proposed: 'Información centralizada' },
  { current: 'Confusión en horas punta', proposed: 'Estados claros y seguimiento' },
  { current: 'Mayor carga cognitiva', proposed: 'Interfaz accesible y simple' },
];

const responseItems = [
  'Centraliza la información de pedidos en un solo sistema',
  'Reduce errores asociados al registro manual',
  'Permite un seguimiento claro del estado de cada pedido',
  'Mejora la usabilidad para adultos mayores mediante una interfaz accesible',
];

const flowItems = [
  {
    title: 'Registro del pedido',
    description: 'Selección guiada de productos mediante una interfaz simple y visual.',
  },
  {
    title: 'Confirmación del pedido',
    description: 'Validación del contenido antes de su envío, reduciendo errores.',
  },
  {
    title: 'Preparación',
    description: 'El pedido pasa a estado “en preparación”, permitiendo su seguimiento.',
  },
  {
    title: 'Entrega',
    description: 'El sistema indica cuándo el pedido está listo para ser entregado.',
  },
  {
    title: 'Cierre del pedido',
    description: 'Registro final del pedido como completado.',
  },
];

const viabilityItems = [
  'Acceso desde distintos dispositivos (PC, tablet)',
  'Bajo costo de implementación',
  'Escalabilidad según el crecimiento del negocio',
  'Adaptabilidad a distintos contextos de pymes gastronómicas',
];

const validationItems = [
  'Facilidad de uso',
  'Claridad de la interfaz',
  'Reducción de errores',
  'Comprensión del flujo de trabajo',
];

const footerMeta = [
  'Luciano Villanueva Ramírez',
  'Ingeniería en Ejecución en Computación e Informática',
  'Universidad del Bío-Bío',
];
---

<BaseLayout
  title="Sistema de pedidos accesible para pymes gastronómicas"
  description="Sistema de pedidos accesible que reduce errores y mejora la atención en pymes gastronómicas."
>
  <div class="relative overflow-hidden">
    <header class="sticky top-0 z-10 border-b border-white/8 bg-[#0f172acc] backdrop-blur-xl">
      <div class="relative z-[1] mx-auto flex w-[min(calc(100%-2rem),1180px)] flex-col items-start justify-between gap-5 py-4 lg:flex-row lg:items-center">
        <a
          class="inline-flex items-center gap-3.5 font-display text-base font-bold tracking-[-0.03em] text-slate-50"
          href="#inicio"
          aria-label="Ir al inicio del proyecto"
        >
          <span>Sistema de pedidos accesible</span>
        </a>

        <nav class="flex flex-wrap justify-end gap-2" aria-label="Secciones principales">
          {
            sections.map((section) => (
              <a
                class="rounded-full px-4 py-3 text-[0.96rem] text-slate-400 transition hover:bg-white/8 hover:text-slate-50 focus-visible:bg-white/8 focus-visible:text-slate-50"
                href={section.href ?? `#${section.id}`}
              >
                {section.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main>
      <section id="inicio" class="relative overflow-hidden text-white" data-reveal>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(56,189,248,0.08),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(34,197,94,0.06),transparent_30%)]"></div>

        <div class="relative mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-28">
          <div class="max-w-4xl">
            <p class="mb-4 inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-1 text-sm text-sky-300">
              Proyecto de título - Presentación de propuesta
            </p>

            <p class="mb-4 text-sm font-medium text-sky-400 md:text-base">
              Diseñado para adultos mayores y entornos de alta demanda
            </p>

            <h1 class="max-w-4xl text-4xl font-bold leading-tight md:text-6xl">
              Sistema de pedidos
              <span class="text-sky-400"> accesible</span>
              que reduce errores y mejora la atención
            </h1>

            <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
              Una propuesta de sistema digital de uso interno para organizar pedidos, hacer seguimiento
              claro y facilitar la operación diaria en pymes gastronómicas con usuarios de distintos niveles tecnológicos.
            </p>

            <div class="mt-8 flex flex-wrap gap-4" data-reveal style="--reveal-delay: 120ms;">
              <a
                href="#problema"
                class="button-lift rounded-full bg-green-500 px-6 py-3 font-semibold text-slate-950 transition hover:bg-green-400"
              >
<<<<<<< Updated upstream
                Revisar propuesta
              </a>
              <a
                href="/Propuesta.github.io/demo/"
                class="button-lift rounded-full border border-white/10 bg-white/5 px-6 py-3 font-semibold text-slate-100 transition hover:bg-white/10"
              >
                Ver prototipo
=======
                Ver accesibilidad aplicada
>>>>>>> Stashed changes
              </a>
            </div>

            <div class="mt-5 text-sm text-slate-400">
              Propuesta centrada en la digitalización del proceso, la accesibilidad y la adopción real del sistema.
            </div>

            <div class="mt-10 grid gap-4 md:grid-cols-3">
              <div class="surface-hover rounded-2xl border border-white/10 bg-[#0B1120] p-5 hover:border-sky-400/30" data-reveal style="--reveal-delay: 180ms;">
                <p class="text-sm font-semibold text-white">Menos errores</p>
                <p class="mt-2 text-sm text-slate-400">
                  El sistema ayuda a reducir equivocaciones en el registro y la entrega de pedidos.
                </p>
              </div>

              <div class="surface-hover rounded-2xl border border-white/10 bg-[#0B1120] p-5 hover:border-sky-400/30" data-reveal style="--reveal-delay: 240ms;">
                <p class="text-sm font-semibold text-white">Más claridad</p>
                <p class="mt-2 text-sm text-slate-400">
                  Cada pedido mantiene un estado visible y un flujo más comprensible para atención y cocina.
                </p>
              </div>

              <div class="surface-hover rounded-2xl border border-white/10 bg-[#0B1120] p-5 hover:border-sky-400/30" data-reveal style="--reveal-delay: 300ms;">
                <p class="text-sm font-semibold text-white">Uso accesible</p>
                <p class="mt-2 text-sm text-slate-400">
                  La interfaz se adapta mejor a adultos mayores y usuarios con baja experiencia digital.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="contexto-negocio" class="py-16 text-white" data-reveal>
        <div class="mx-auto max-w-6xl px-6">
          <div class="rounded-[32px] border border-white/10 bg-[#0B1120] p-8 shadow-[0_24px_80px_rgba(2,6,23,0.28)]">
            <p class="text-sm font-medium uppercase tracking-[0.2em] text-sky-400">
              Contexto del negocio
            </p>
            <h2 class="mt-3 text-3xl font-bold md:text-4xl">
              Una propuesta pensada para una pyme gastronómica real
            </h2>
            <p class="mt-4 max-w-4xl text-slate-300">
              El proyecto se desarrolla en el contexto de una pyme del rubro gastronómico, donde el
              proceso de toma de pedidos se realiza actualmente de forma manual, generando dificultades
              en la organización, especialmente en horarios de alta demanda.
            </p>
            <p class="mt-4 max-w-4xl text-slate-400">
              Además, el sistema debe considerar usuarios con distintos niveles de experiencia digital,
              incluyendo adultos mayores.
            </p>
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="problema" data-reveal>
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(320px,1.08fr)] lg:items-start">
            <div class="grid gap-5">
              <div class="grid max-w-[42rem] gap-3.5">
                <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Problema</span>
                <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-50">
                  El sistema actual genera errores y desorden en horas punta.
                </h2>
                <p class="m-0 max-w-[38rem] text-[1.05rem] leading-7 text-slate-400 sm:leading-8">
                  Según el levantamiento del proyecto, el proceso manual permite operar el local, pero pierde claridad,
                  aumenta la carga de trabajo y dificulta mantener el control cuando crece la demanda.
                </p>
              </div>

              <div class="rounded-[28px] border border-white/8 bg-[#0b1120] p-6">
                <div class="mb-4 flex items-center justify-between gap-4">
                  <div>
                    <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Proceso actual</p>
                    <h3 class="mt-2 text-2xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
                      Flujo manual de atención
                    </h3>
                  </div>
                  <span class="rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1 text-xs font-bold text-amber-300">
                    Alto riesgo en horas punta
                  </span>
                </div>

                <div class="grid gap-4">
                  {
                    problemFlow.map((step, index) => (
                      <div class="surface-hover flex gap-4 rounded-3xl border border-white/8 bg-white/4 p-4">
                        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-2xl bg-slate-50 text-sm font-bold text-slate-950">
                          0{index + 1}
                        </span>
                        <p class="m-0 text-[0.98rem] leading-7 text-slate-300">{step}</p>
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              {
                problemIssues.map((item) => (
                  <article class="surface-hover rounded-[28px] border border-white/8 bg-[#0b1120] p-6 shadow-[0_18px_60px_rgba(2,6,23,0.28)] hover:border-cyan-300/30">
                    <h3 class="text-xl leading-tight font-bold tracking-[-0.04em] text-slate-50">
                      {item.title}
                    </h3>
                    <p class="mt-3 text-[0.98rem] leading-7 text-slate-400">
                      {item.description}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section class="py-20 text-white" id="comparacion" data-reveal>
        <div class="mx-auto max-w-6xl px-6">
          <div class="mb-12 text-center">
            <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-sky-400">
              ¿Por qué esta solución es mejor?
            </p>
            <h2 class="text-3xl font-bold md:text-4xl">
              Una propuesta más clara, controlada y viable que el método actual
            </h2>
          </div>

          <div class="overflow-hidden rounded-[32px] border border-white/10 bg-[#0B1120] shadow-[0_24px_80px_rgba(2,6,23,0.3)]">
            <div class="grid grid-cols-2 border-b border-white/10 bg-[#08111f]">
              <div class="px-6 py-4 text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Método actual</div>
              <div class="px-6 py-4 text-sm font-semibold uppercase tracking-[0.2em] text-sky-300">Propuesta del sistema</div>
            </div>
            {
              comparisonRows.map((row) => (
                <div class="grid grid-cols-2 border-b border-white/6 last:border-b-0">
                  <div class="px-6 py-5 text-slate-300">{row.current}</div>
                  <div class="px-6 py-5 font-medium text-slate-50">{row.proposed}</div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section class="px-0 py-14 sm:py-18" id="propuesta" data-reveal>
        <div class="relative z-[1] mx-auto w-[min(calc(100%-2rem),1180px)]">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,0.98fr)_minmax(320px,1.02fr)] lg:items-start">
            <div class="grid gap-5">
              <div class="grid max-w-[44rem] gap-3.5">
                <span class="inline-flex w-fit items-center gap-2 rounded-full bg-cyan-400/12 px-3.5 py-2 text-[0.88rem] font-bold text-cyan-300 before:h-[0.45rem] before:w-[0.45rem] before:rounded-full before:bg-current before:content-['']">Propuesta</span>
                <h2 class="m-0 max-w-[12ch] text-[clamp(2rem,4vw,3.4rem)] leading-[0.98] font-extrabold tracking-[-0.045em] text-slate-50">
