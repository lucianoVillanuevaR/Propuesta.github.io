        accessibilityDesignSection.dataset.accessible = accessible ? 'true' : 'false';
        accessibilityDesignSection.style.setProperty('--ui-zoom', `${zoom}`);
        accessibilityModeToggle.setAttribute('aria-pressed', accessible ? 'true' : 'false');
        accessModeStandardLabel.classList.toggle('is-active', !accessible);
        accessModeAccessibleLabel.classList.toggle('is-active', accessible);
        zoomValueLabel.textContent = `Zoom ${Math.round(zoom * 100)}%`;
        zoomDecreaseBtn.disabled = zoom <= 0.8;
